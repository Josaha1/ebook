---
const { variant = 'ar' } = Astro.props;
---
<div class="scene-3d">
  <div class="phone-frame relative w-[240px] aspect-[9/19] mx-auto">
    <!-- notch -->
    <div class="absolute top-2 left-1/2 -translate-x-1/2 w-24 h-5 bg-black rounded-b-2xl z-20 flex items-center justify-end px-3">
      <span class="w-1.5 h-1.5 rounded-full bg-zinc-700"></span>
    </div>

    <div class="phone-screen absolute inset-[0.375rem]">
      {variant === 'ar' && (
        <div class="absolute inset-0 overflow-hidden bg-white">
          <!-- status bar -->
          <div class="absolute top-0 inset-x-0 h-6 flex items-center justify-between px-4 pt-1 text-[9px] font-semibold text-zinc-900 z-10">
            <span class="font-mono">9:41</span>
            <div class="flex items-center gap-1">
              <svg class="w-3 h-2.5" viewBox="0 0 18 12" fill="none"><path d="M1 8h2M5 6h2M9 4h2M13 2h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              <span>100</span>
            </div>
          </div>

          <!-- app header -->
          <div class="absolute top-7 inset-x-0 px-4 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="w-7 h-7 rounded-lg brand-gradient grid place-items-center text-white font-bold text-[10px]">A</div>
              <span class="text-[11px] font-semibold text-zinc-900">Aurasma</span>
            </div>
            <span class="text-[10px] font-mono text-indigo-600 font-semibold">● LIVE</span>
          </div>

          <!-- camera viewfinder -->
          <div class="absolute top-20 left-3 right-3 bottom-16 rounded-xl overflow-hidden bg-gradient-to-br from-indigo-100 via-purple-50 to-pink-100">
            <!-- scene grid -->
            <div class="absolute inset-0 opacity-30" style="background-image: linear-gradient(rgba(79, 70, 229, 0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(79, 70, 229, 0.3) 1px, transparent 1px); background-size: 20px 20px;"></div>

            <!-- corner brackets -->
            <div class="absolute top-3 left-3 w-5 h-5 border-t-2 border-l-2 border-indigo-600"></div>
            <div class="absolute top-3 right-3 w-5 h-5 border-t-2 border-r-2 border-indigo-600"></div>
            <div class="absolute bottom-3 left-3 w-5 h-5 border-b-2 border-l-2 border-indigo-600"></div>
            <div class="absolute bottom-3 right-3 w-5 h-5 border-b-2 border-r-2 border-indigo-600"></div>

            <!-- floating AR cube -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="relative">
                <div class="absolute inset-0 rounded-2xl brand-gradient opacity-60 blur-xl float-y"></div>
                <div class="relative w-20 h-20 rounded-2xl brand-gradient shadow-2xl flex items-center justify-center text-white font-bold text-2xl float-y">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25M21 7.5v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"/></svg>
                </div>
                <span class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-emerald-400 border-2 border-white pulse-ring"></span>
                <span class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-emerald-400 border-2 border-white"></span>
              </div>
            </div>

            <!-- overlay tag -->
            <div class="absolute top-4 left-4 bg-white/95 rounded-full px-2 py-1 text-[9px] font-semibold text-indigo-700 shadow-md">📍 Detected</div>
          </div>

          <!-- bottom controls -->
          <div class="absolute bottom-3 inset-x-3">
            <div class="flex items-center justify-between gap-2 mb-2">
              <div class="h-1.5 flex-1 rounded-full bg-zinc-200 overflow-hidden">
                <div class="h-full w-2/3 brand-gradient rounded-full"></div>
              </div>
              <span class="text-[9px] font-mono font-semibold text-zinc-700">67%</span>
            </div>
            <div class="flex items-center justify-around">
              <div class="w-6 h-6 rounded-full bg-zinc-100 grid place-items-center">
                <svg class="w-3 h-3 text-zinc-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              </div>
              <div class="w-10 h-10 rounded-full brand-gradient grid place-items-center shadow-lg">
                <div class="w-8 h-8 rounded-full border-2 border-white"></div>
              </div>
              <div class="w-6 h-6 rounded-full bg-zinc-100 grid place-items-center">
                <svg class="w-3 h-3 text-zinc-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14M4 6h16a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V8a2 2 0 012-2z"/></svg>
              </div>
            </div>
          </div>
        </div>
      )}

      {variant === 'qr' && (
        <div class="absolute inset-0 overflow-hidden bg-white">
          <div class="absolute top-0 inset-x-0 h-6 flex items-center justify-between px-4 pt-1 text-[9px] font-semibold text-zinc-900 z-10">
            <span class="font-mono">9:41</span>
            <span class="text-[10px]">100</span>
          </div>

          <div class="absolute top-8 inset-x-0 px-4 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="w-7 h-7 rounded-lg bg-green-600 grid place-items-center text-white font-bold text-[10px]">L</div>
              <span class="text-[11px] font-semibold text-zinc-900">LINE · Scan</span>
            </div>
            <span class="text-[10px] font-mono text-green-600 font-semibold">◎</span>
          </div>

          <div class="absolute top-20 left-3 right-3 rounded-xl overflow-hidden bg-zinc-900">
            <div class="p-4 flex flex-col items-center gap-3">
              <!-- QR -->
              <div class="relative w-32 h-32 bg-white rounded-lg p-2">
                <svg viewBox="0 0 100 100" class="w-full h-full text-zinc-900" aria-hidden="true" fill="currentColor">
                  <rect x="5" y="5" width="25" height="25"/>
                  <rect x="10" y="10" width="15" height="15" fill="#fff"/>
                  <rect x="14" y="14" width="7" height="7"/>
                  <rect x="70" y="5" width="25" height="25"/>
                  <rect x="75" y="10" width="15" height="15" fill="#fff"/>
                  <rect x="79" y="14" width="7" height="7"/>
                  <rect x="5" y="70" width="25" height="25"/>
                  <rect x="10" y="75" width="15" height="15" fill="#fff"/>
                  <rect x="14" y="79" width="7" height="7"/>
                  <rect x="40" y="10" width="6" height="6"/><rect x="50" y="10" width="6" height="6"/>
                  <rect x="60" y="16" width="6" height="6"/><rect x="40" y="20" width="6" height="6"/>
                  <rect x="52" y="22" width="6" height="6"/><rect x="36" y="36" width="6" height="6"/>
                  <rect x="46" y="36" width="6" height="6"/><rect x="56" y="36" width="6" height="6"/>
                  <rect x="66" y="36" width="6" height="6"/><rect x="40" y="46" width="6" height="6"/>
                  <rect x="50" y="48" width="6" height="6"/><rect x="60" y="46" width="6" height="6"/>
                  <rect x="72" y="48" width="6" height="6"/><rect x="36" y="56" width="6" height="6"/>
                  <rect x="46" y="58" width="6" height="6"/><rect x="56" y="56" width="6" height="6"/>
                  <rect x="40" y="68" width="6" height="6"/><rect x="56" y="68" width="6" height="6"/>
                  <rect x="68" y="72" width="6" height="6"/><rect x="42" y="78" width="6" height="6"/>
                  <rect x="54" y="82" width="6" height="6"/><rect x="66" y="82" width="6" height="6"/>
                  <rect x="78" y="52" width="6" height="6"/><rect x="85" y="62" width="6" height="6"/>
                </svg>
                <div class="qr-scanline"></div>
                <!-- corner brackets -->
                <div class="absolute -top-1 -left-1 w-3 h-3 border-t-2 border-l-2 border-green-400"></div>
                <div class="absolute -top-1 -right-1 w-3 h-3 border-t-2 border-r-2 border-green-400"></div>
                <div class="absolute -bottom-1 -left-1 w-3 h-3 border-b-2 border-l-2 border-green-400"></div>
                <div class="absolute -bottom-1 -right-1 w-3 h-3 border-b-2 border-r-2 border-green-400"></div>
              </div>
              <div class="text-white text-[10px] font-semibold">Align QR within frame</div>
            </div>
          </div>

          <div class="absolute bottom-6 inset-x-3">
            <div class="rounded-xl bg-green-600 text-white py-2.5 text-center text-[11px] font-semibold">
              เปิดลิงก์ · Open Link
            </div>
          </div>
        </div>
      )}

      {variant === 'doc' && (
        <div class="absolute inset-0 overflow-hidden bg-gradient-to-br from-amber-50 to-orange-50">
          <div class="absolute top-0 inset-x-0 h-6 flex items-center justify-between px-4 pt-1 text-[9px] font-semibold text-zinc-900 z-10">
            <span class="font-mono">9:41</span>
            <span>100</span>
          </div>

          <div class="absolute top-8 inset-x-3 bottom-4 bg-white rounded-xl p-4 shadow-inner overflow-hidden">
            <!-- document header -->
            <div class="pb-3 border-b border-amber-200">
              <div class="h-2 w-20 rounded-full bg-zinc-800"></div>
              <div class="mt-1.5 h-1 w-14 rounded-full bg-amber-400"></div>
            </div>

            <!-- paragraph lines -->
            <div class="mt-4 space-y-1.5">
              <div class="h-1 w-full rounded-full bg-zinc-300"></div>
              <div class="h-1 w-[92%] rounded-full bg-zinc-300"></div>
              <div class="h-1 w-[85%] rounded-full bg-zinc-300"></div>
              <div class="h-1 w-[95%] rounded-full bg-zinc-300"></div>
              <div class="h-1 w-[70%] rounded-full bg-zinc-300"></div>
            </div>

            <!-- image block -->
            <div class="mt-3 h-16 rounded-md bg-gradient-to-br from-amber-100 to-orange-200 grid place-items-center">
              <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/><path d="M21 15l-5-5L5 21"/></svg>
            </div>

            <div class="mt-3 space-y-1.5">
              <div class="h-1 w-full rounded-full bg-zinc-300"></div>
              <div class="h-1 w-[78%] rounded-full bg-zinc-300"></div>
              <div class="h-1 w-[88%] rounded-full bg-zinc-300"></div>
            </div>

            <!-- torn / damaged corner -->
            <div class="absolute -right-1 -bottom-1 w-10 h-10 rotate-12 opacity-60" style="background: linear-gradient(135deg, transparent 50%, rgba(180, 83, 9, 0.2) 50%);"></div>
          </div>

          <!-- "old paper" tag -->
          <div class="absolute bottom-1.5 left-1/2 -translate-x-1/2 text-[9px] font-semibold text-amber-700">
            เอกสารกระดาษ · ยุคเก่า
          </div>
        </div>
      )}
    </div>
  </div>
</div>
