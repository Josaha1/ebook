---
const { variant = 'ar' } = Astro.props;
---
<div class="scene-3d">
  <div class="phone-frame relative w-[240px] aspect-[9/19] mx-auto">
    <div class="absolute top-2.5 left-1/2 -translate-x-1/2 w-20 h-5 bg-slate-900 rounded-full z-20"></div>
    <div class="phone-screen absolute inset-[0.5rem] bg-gradient-to-br from-indigo-100 via-white to-pink-50 dark:from-slate-900 dark:via-slate-950 dark:to-purple-950">
      {variant === 'ar' && (
        <div class="absolute inset-0 overflow-hidden">
          <div class="ar-grid-bg absolute inset-0 opacity-40"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="relative w-32 h-32">
              <div class="absolute inset-0 rounded-3xl ar-gradient opacity-80 blur-xl float-y"></div>
              <div class="absolute inset-3 rounded-2xl ar-gradient shadow-2xl flex items-center justify-center text-white font-display font-black text-3xl float-y">AR</div>
              <span class="absolute -top-3 -right-3 w-3 h-3 rounded-full bg-cyan-400 pulse-ring"></span>
              <span class="absolute -top-3 -right-3 w-3 h-3 rounded-full bg-cyan-400"></span>
            </div>
          </div>
          <div class="absolute bottom-3 left-3 right-3 flex items-center gap-2">
            <div class="h-1.5 flex-1 rounded-full bg-slate-900/20 dark:bg-white/10 overflow-hidden">
              <div class="h-full w-2/3 ar-gradient rounded-full"></div>
            </div>
            <span class="text-[10px] font-semibold text-slate-600 dark:text-slate-300">AR · LIVE</span>
          </div>
          <div class="absolute top-10 left-3 px-2 py-1 rounded-md bg-white/80 dark:bg-slate-900/80 backdrop-blur text-[10px] font-semibold">📍 Aurasma</div>
        </div>
      )}
      {variant === 'qr' && (
        <div class="absolute inset-0 flex flex-col items-center justify-center p-6 gap-3">
          <div class="relative w-32 h-32 bg-white rounded-lg p-2 border border-slate-200">
            <svg viewBox="0 0 100 100" class="w-full h-full" aria-hidden="true">
              <rect x="5" y="5" width="25" height="25" fill="#0B1020" />
              <rect x="10" y="10" width="15" height="15" fill="#fff" />
              <rect x="14" y="14" width="7" height="7" fill="#0B1020" />
              <rect x="70" y="5" width="25" height="25" fill="#0B1020" />
              <rect x="75" y="10" width="15" height="15" fill="#fff" />
              <rect x="79" y="14" width="7" height="7" fill="#0B1020" />
              <rect x="5" y="70" width="25" height="25" fill="#0B1020" />
              <rect x="10" y="75" width="15" height="15" fill="#fff" />
              <rect x="14" y="79" width="7" height="7" fill="#0B1020" />
              <g fill="#0B1020">
                <rect x="40" y="10" width="6" height="6"/><rect x="50" y="10" width="6" height="6"/><rect x="60" y="16" width="6" height="6"/>
                <rect x="40" y="20" width="6" height="6"/><rect x="52" y="22" width="6" height="6"/>
                <rect x="36" y="36" width="6" height="6"/><rect x="46" y="36" width="6" height="6"/><rect x="56" y="36" width="6" height="6"/><rect x="66" y="36" width="6" height="6"/>
                <rect x="40" y="46" width="6" height="6"/><rect x="50" y="48" width="6" height="6"/><rect x="60" y="46" width="6" height="6"/><rect x="72" y="48" width="6" height="6"/>
                <rect x="36" y="56" width="6" height="6"/><rect x="46" y="58" width="6" height="6"/><rect x="56" y="56" width="6" height="6"/>
                <rect x="40" y="68" width="6" height="6"/><rect x="56" y="68" width="6" height="6"/><rect x="68" y="72" width="6" height="6"/>
                <rect x="42" y="78" width="6" height="6"/><rect x="54" y="82" width="6" height="6"/><rect x="66" y="82" width="6" height="6"/>
                <rect x="78" y="52" width="6" height="6"/><rect x="85" y="62" width="6" height="6"/>
              </g>
            </svg>
            <div class="qr-scanline"></div>
          </div>
          <div class="text-xs font-semibold text-slate-700 dark:text-slate-300">Scan via LINE</div>
        </div>
      )}
      {variant === 'doc' && (
        <div class="absolute inset-0 p-4 space-y-2">
          <div class="h-2 w-1/2 rounded bg-slate-800 dark:bg-slate-200"></div>
          <div class="h-1.5 w-full rounded bg-slate-300 dark:bg-slate-700"></div>
          <div class="h-1.5 w-5/6 rounded bg-slate-300 dark:bg-slate-700"></div>
          <div class="h-1.5 w-full rounded bg-slate-300 dark:bg-slate-700"></div>
          <div class="h-1.5 w-3/4 rounded bg-slate-300 dark:bg-slate-700"></div>
          <div class="mt-4 h-20 rounded bg-gradient-to-br from-indigo-200 to-pink-200 dark:from-indigo-900/60 dark:to-pink-900/60"></div>
          <div class="h-1.5 w-full rounded bg-slate-300 dark:bg-slate-700"></div>
          <div class="h-1.5 w-2/3 rounded bg-slate-300 dark:bg-slate-700"></div>
        </div>
      )}
    </div>
  </div>
</div>
