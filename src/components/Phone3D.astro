---
const { variant = 'ar', width = 240 } = Astro.props;
---
<div class="phone-frame relative mx-auto" style={`width: ${width}px;`}>
  <div class="phone-screen relative overflow-hidden" style="aspect-ratio: 9 / 19.5;">
    <!-- notch -->
    <div class="absolute top-1.5 left-1/2 -translate-x-1/2 w-[40%] h-4 bg-black rounded-b-2xl z-30 flex items-center justify-end pr-3">
      <span class="w-1 h-1 rounded-full bg-zinc-700"></span>
    </div>

    {variant === 'ar' && (
      <div class="absolute inset-0 bg-white">
        <!-- status bar -->
        <div class="absolute top-0 inset-x-0 h-6 flex items-center justify-between px-4 pt-1 text-[9px] font-semibold text-zinc-900 z-20">
          <span class="font-mono">9:41</span>
          <span class="font-mono">100%</span>
        </div>

        <!-- app header -->
        <div class="absolute top-7 inset-x-0 px-3.5 flex items-center justify-between z-10">
          <div class="flex items-center gap-1.5">
            <div class="w-6 h-6 rounded-md brand-gradient grid place-items-center text-white font-bold text-[10px]">A</div>
            <span class="text-[10px] font-semibold text-zinc-900">Aurasma</span>
          </div>
          <span class="text-[9px] font-mono text-indigo-600 font-semibold flex items-center gap-1">
            <span class="w-1.5 h-1.5 rounded-full bg-indigo-600 animate-pulse"></span>
            LIVE
          </span>
        </div>

        <!-- camera viewfinder -->
        <div class="absolute top-[4rem] left-2.5 right-2.5 bottom-[4.5rem] rounded-xl overflow-hidden bg-gradient-to-br from-indigo-100 via-purple-50 to-pink-100">
          <!-- grid -->
          <div class="absolute inset-0 opacity-30" style="background-image: linear-gradient(rgba(79, 70, 229, 0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(79, 70, 229, 0.3) 1px, transparent 1px); background-size: 16px 16px;"></div>
          <!-- brackets -->
          <div class="absolute top-2 left-2 w-4 h-4 border-t-2 border-l-2 border-indigo-600"></div>
          <div class="absolute top-2 right-2 w-4 h-4 border-t-2 border-r-2 border-indigo-600"></div>
          <div class="absolute bottom-2 left-2 w-4 h-4 border-b-2 border-l-2 border-indigo-600"></div>
          <div class="absolute bottom-2 right-2 w-4 h-4 border-b-2 border-r-2 border-indigo-600"></div>
          <!-- floating cube -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="relative">
              <div class="absolute inset-0 rounded-xl brand-gradient opacity-60 blur-lg float-y"></div>
              <div class="relative w-16 h-16 rounded-xl brand-gradient shadow-xl grid place-items-center text-white float-y">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25M21 7.5v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"/></svg>
              </div>
            </div>
          </div>
          <!-- tag -->
          <div class="absolute top-2.5 left-1/2 -translate-x-1/2 bg-white/95 rounded-full px-2 py-0.5 text-[8px] font-semibold text-indigo-700 shadow">Detected</div>
        </div>

        <!-- bottom bar -->
        <div class="absolute bottom-2 inset-x-3">
          <div class="flex items-center gap-2 mb-1.5">
            <div class="h-1 flex-1 rounded-full bg-zinc-200 overflow-hidden">
              <div class="h-full w-2/3 brand-gradient rounded-full"></div>
            </div>
            <span class="text-[8px] font-mono font-semibold text-zinc-700">67%</span>
          </div>
          <div class="flex items-center justify-around">
            <div class="w-5 h-5 rounded-full bg-zinc-100"></div>
            <div class="w-8 h-8 rounded-full brand-gradient grid place-items-center shadow">
              <div class="w-6 h-6 rounded-full border-2 border-white"></div>
            </div>
            <div class="w-5 h-5 rounded-full bg-zinc-100"></div>
          </div>
        </div>
      </div>
    )}

    {variant === 'qr' && (
      <div class="absolute inset-0 bg-white">
        <div class="absolute top-0 inset-x-0 h-6 flex items-center justify-between px-4 pt-1 text-[9px] font-semibold text-zinc-900 z-20">
          <span class="font-mono">9:41</span>
          <span class="font-mono">100%</span>
        </div>

        <div class="absolute top-7 inset-x-0 px-3.5 flex items-center justify-between">
          <div class="flex items-center gap-1.5">
            <div class="w-6 h-6 rounded-md bg-green-500 grid place-items-center text-white font-bold text-[10px]">L</div>
            <span class="text-[10px] font-semibold text-zinc-900">LINE · Scan</span>
          </div>
        </div>

        <div class="absolute top-[4rem] left-2.5 right-2.5 bottom-[3.5rem] rounded-xl overflow-hidden bg-zinc-900 flex flex-col items-center justify-center gap-2 p-3">
          <div class="relative w-[75%] aspect-square bg-white rounded-md p-1.5">
            <svg viewBox="0 0 100 100" class="w-full h-full text-zinc-900" aria-hidden="true" fill="currentColor">
              <rect x="5" y="5" width="25" height="25"/>
              <rect x="10" y="10" width="15" height="15" fill="#fff"/>
              <rect x="14" y="14" width="7" height="7"/>
              <rect x="70" y="5" width="25" height="25"/>
              <rect x="75" y="10" width="15" height="15" fill="#fff"/>
              <rect x="79" y="14" width="7" height="7"/>
              <rect x="5" y="70" width="25" height="25"/>
              <rect x="10" y="75" width="15" height="15" fill="#fff"/>
              <rect x="14" y="79" width="7" height="7"/>
              <rect x="40" y="10" width="6" height="6"/><rect x="50" y="10" width="6" height="6"/>
              <rect x="60" y="16" width="6" height="6"/><rect x="40" y="20" width="6" height="6"/>
              <rect x="52" y="22" width="6" height="6"/><rect x="36" y="36" width="6" height="6"/>
              <rect x="46" y="36" width="6" height="6"/><rect x="56" y="36" width="6" height="6"/>
              <rect x="66" y="36" width="6" height="6"/><rect x="40" y="46" width="6" height="6"/>
              <rect x="50" y="48" width="6" height="6"/><rect x="60" y="46" width="6" height="6"/>
              <rect x="72" y="48" width="6" height="6"/><rect x="36" y="56" width="6" height="6"/>
              <rect x="46" y="58" width="6" height="6"/><rect x="56" y="56" width="6" height="6"/>
              <rect x="40" y="68" width="6" height="6"/><rect x="56" y="68" width="6" height="6"/>
              <rect x="68" y="72" width="6" height="6"/><rect x="42" y="78" width="6" height="6"/>
              <rect x="54" y="82" width="6" height="6"/><rect x="66" y="82" width="6" height="6"/>
              <rect x="78" y="52" width="6" height="6"/><rect x="85" y="62" width="6" height="6"/>
            </svg>
            <div class="qr-scanline"></div>
            <div class="absolute -top-1 -left-1 w-3 h-3 border-t-2 border-l-2 border-green-400"></div>
            <div class="absolute -top-1 -right-1 w-3 h-3 border-t-2 border-r-2 border-green-400"></div>
            <div class="absolute -bottom-1 -left-1 w-3 h-3 border-b-2 border-l-2 border-green-400"></div>
            <div class="absolute -bottom-1 -right-1 w-3 h-3 border-b-2 border-r-2 border-green-400"></div>
          </div>
          <div class="text-white text-[9px] font-semibold">Align QR within frame</div>
        </div>

        <div class="absolute bottom-3 inset-x-3">
          <div class="rounded-lg bg-green-500 text-white py-2 text-center text-[10px] font-semibold">
            เปิดลิงก์
          </div>
        </div>
      </div>
    )}

    {variant === 'doc' && (
      <div class="absolute inset-0 bg-gradient-to-br from-amber-50 to-orange-50">
        <div class="absolute top-0 inset-x-0 h-6 flex items-center justify-between px-4 pt-1 text-[9px] font-semibold text-zinc-900 z-20">
          <span class="font-mono">9:41</span>
          <span class="font-mono">100%</span>
        </div>

        <div class="absolute top-8 inset-x-2.5 bottom-7 bg-white rounded-xl p-3.5 shadow-inner overflow-hidden">
          <div class="pb-2.5 border-b border-amber-200">
            <div class="h-2 w-16 rounded-full bg-zinc-800"></div>
            <div class="mt-1 h-1 w-10 rounded-full bg-amber-400"></div>
          </div>
          <div class="mt-3 space-y-1">
            <div class="h-1 w-full rounded-full bg-zinc-300"></div>
            <div class="h-1 w-[92%] rounded-full bg-zinc-300"></div>
            <div class="h-1 w-[85%] rounded-full bg-zinc-300"></div>
            <div class="h-1 w-[95%] rounded-full bg-zinc-300"></div>
            <div class="h-1 w-[70%] rounded-full bg-zinc-300"></div>
          </div>
          <div class="mt-3 h-14 rounded-md bg-gradient-to-br from-amber-100 to-orange-200 grid place-items-center">
            <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/><path d="M21 15l-5-5L5 21"/></svg>
          </div>
          <div class="mt-2.5 space-y-1">
            <div class="h-1 w-full rounded-full bg-zinc-300"></div>
            <div class="h-1 w-[78%] rounded-full bg-zinc-300"></div>
            <div class="h-1 w-[88%] rounded-full bg-zinc-300"></div>
          </div>
          <div class="absolute -right-1 -bottom-1 w-8 h-8 rotate-12 opacity-60" style="background: linear-gradient(135deg, transparent 50%, rgba(180, 83, 9, 0.2) 50%);"></div>
        </div>

        <div class="absolute bottom-1.5 left-1/2 -translate-x-1/2 text-[9px] font-semibold text-amber-700 whitespace-nowrap">
          เอกสารกระดาษ
        </div>
      </div>
    )}
  </div>
</div>
