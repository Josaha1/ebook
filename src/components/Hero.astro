---
import OrbitScene from './OrbitScene.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section class="relative min-h-[calc(100vh-3.5rem)] flex items-center overflow-hidden border-b border-slate-200 dark:border-slate-800">
  <div class="absolute inset-0 -z-10 ar-grid-bg opacity-50" aria-hidden="true"></div>
  <div class="absolute -top-40 -right-40 w-[32rem] h-[32rem] rounded-full ar-gradient opacity-10 blur-3xl" aria-hidden="true"></div>
  <div class="absolute -bottom-40 -left-40 w-[28rem] h-[28rem] rounded-full bg-cyan-400 opacity-10 blur-3xl" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto px-6 grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center w-full py-20 md:py-24">
    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.3em] text-slate-500 dark:text-slate-400 font-semibold paper rounded-full px-4 py-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-purple-600 animate-pulse"></span>
        Academic Interactive E-Book
      </div>
      <h1 class="mt-6 display-num text-4xl sm:text-5xl md:text-6xl lg:text-[3.75rem] leading-[1.08]">
        ผลการให้ข้อมูล<br/>
        ผู้รับบริการด้วย<br/>
        <span class="ar-gradient-text">สื่อมือถือ AR</span>
      </h1>
      <p class="mt-7 text-base md:text-lg text-slate-600 dark:text-slate-300 leading-[1.85] max-w-xl">
        การศึกษากึ่งทดลองในผู้รับบริการโรงพยาบาลนภาลัย จังหวัดสมุทรสงคราม
        โดยประยุกต์เทคโนโลยี <strong class="text-slate-900 dark:text-white">Augmented Reality</strong> ผ่านแอพพลิเคชัน
        <strong class="text-slate-900 dark:text-white">Aurasma</strong> และ <strong class="text-slate-900 dark:text-white">QR code LINE</strong>
        เพื่อยกระดับการสื่อสารและให้ข้อมูลทางสุขภาพ
      </p>

      <dl class="mt-9 grid grid-cols-3 gap-3 max-w-lg">
        <div class="paper rounded-xl p-4">
          <dt class="text-[10px] uppercase tracking-widest text-slate-500 dark:text-slate-400 font-semibold">รูปแบบ</dt>
          <dd class="mt-1 text-sm font-bold">กึ่งทดลอง</dd>
        </div>
        <div class="paper rounded-xl p-4">
          <dt class="text-[10px] uppercase tracking-widest text-slate-500 dark:text-slate-400 font-semibold">ช่วงเวลา</dt>
          <dd class="mt-1 text-sm font-bold">เม.ย.–ส.ค. 60</dd>
        </div>
        <div class="paper rounded-xl p-4">
          <dt class="text-[10px] uppercase tracking-widest text-slate-500 dark:text-slate-400 font-semibold">กลุ่มตัวอย่าง</dt>
          <dd class="mt-1 text-sm font-bold">20–44 ราย</dd>
        </div>
      </dl>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href={`${base}/chapter-1`} class="group inline-flex items-center gap-2 px-7 py-3.5 ar-gradient text-white rounded-xl font-semibold shadow-xl shadow-purple-600/25 hover:shadow-2xl hover:shadow-purple-600/40 transition-shadow">
          เริ่มอ่านบทที่ 1
          <span class="transition-transform group-hover:translate-x-0.5">→</span>
        </a>
        <a href="#abstract" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl font-semibold border border-slate-300 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800 transition">
          อ่านบทคัดย่อ
        </a>
      </div>
    </div>

    <div class="relative">
      <OrbitScene />
    </div>
  </div>
</section>
