---
import OrbitScene from './OrbitScene.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section class="relative min-h-screen hero-ct overflow-hidden flex items-center">
  <div class="absolute inset-0 opacity-[0.06]" aria-hidden="true"
    style="background-image: radial-gradient(rgba(245,239,228,0.4) 1px, transparent 1px); background-size: 30px 30px;"></div>

  <div class="relative max-w-6xl mx-auto px-6 md:px-10 w-full py-20 md:py-28 grid lg:grid-cols-[1.1fr_1fr] gap-16 items-center">
    <div>
      <div class="eyebrow text-gold" style="color: #B8954A;">A Study in Augmented Reality · 2017</div>

      <h1 class="mt-10 font-display italic text-[3rem] sm:text-[3.5rem] md:text-[4.5rem] lg:text-[5.5rem] leading-[1.05] tracking-[-0.02em]">
        The
        <span class="not-italic font-normal">quiet</span>
        <em class="text-gold">revolution</em>
      </h1>
      <h2 class="mt-3 font-serif text-xl md:text-2xl lg:text-3xl font-normal leading-[1.35] text-cream/90 max-w-xl">
        ผลการให้ข้อมูลผู้รับบริการ<br/>
        โรงพยาบาลนภาลัย จังหวัดสมุทรสงคราม<br/>
        <span class="italic text-gold">ด้วยสื่อมือถือผ่านเทคโนโลยี AR</span>
      </h2>

      <div class="mt-10 max-w-lg">
        <div class="gold-line w-20 mb-7"></div>
        <p class="font-serif text-base md:text-lg leading-[1.85] text-cream/80">
          การศึกษากึ่งทดลองในผู้รับบริการ โดยประยุกต์เทคโนโลยี <em class="italic text-gold">Augmented Reality</em>
          ผ่านแอพพลิเคชัน Aurasma และ QR code LINE เพื่อยกระดับการสื่อสารและให้ข้อมูลทางสุขภาพ
        </p>
      </div>

      <div class="mt-10 flex items-center gap-5 flex-wrap">
        <a href={`${base}/chapter-1`} class="group inline-flex items-center gap-3 px-8 py-3.5 bg-gold text-ink rounded-none font-sans font-semibold tracking-wider text-sm uppercase hover:bg-cream transition">
          เริ่มอ่าน
          <span class="transition-transform group-hover:translate-x-1">→</span>
        </a>
        <a href="#masthead" class="inline-flex items-center gap-2 font-serif italic text-base text-cream/80 hover:text-gold transition">
          <span class="w-8 h-px bg-current"></span>
          หรือข้ามไปบทคัดย่อ
        </a>
      </div>
    </div>

    <div class="relative hidden lg:block">
      <OrbitScene />
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-gold opacity-70">
    <span class="text-[10px] font-sans uppercase tracking-[0.35em]">Scroll</span>
    <span class="animate-bounce">↓</span>
  </div>
</section>
