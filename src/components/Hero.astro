---
import OrbitScene from './OrbitScene.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section class="relative overflow-hidden">
  <!-- Subtle background pattern -->
  <div class="absolute inset-0 -z-10 brand-gradient-subtle"></div>
  <div class="absolute -top-20 -right-20 w-[28rem] h-[28rem] rounded-full brand-gradient opacity-[0.08] blur-3xl" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 sm:pt-28 md:pt-36 pb-16 md:pb-24">
    <div class="grid lg:grid-cols-[1.15fr_1fr] gap-10 lg:gap-16 items-center">
      <div>
        <span class="kicker">
          <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>
          การศึกษากึ่งทดลอง · 2560
        </span>

        <h1 class="mt-6 sm:mt-7 font-semibold leading-[1.1] tracking-tight"
          style="font-size: clamp(2rem, 5.5vw, 3.5rem);">
          ผลการให้ข้อมูล<br/>
          ผู้รับบริการด้วย<br/>
          <span class="brand-gradient-text">สื่อมือถือ AR</span>
        </h1>

        <p class="mt-6 text-base sm:text-lg md:text-xl leading-[1.75] text-zinc-600 dark:text-zinc-400 max-w-xl">
          การศึกษากึ่งทดลองในผู้รับบริการโรงพยาบาลนภาลัย จังหวัดสมุทรสงคราม
          โดยประยุกต์เทคโนโลยี <em class="text-indigo-600 dark:text-indigo-400 not-italic font-medium">Augmented Reality</em>
          ผ่านแอพพลิเคชัน Aurasma และ QR code LINE
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href={`${base}/chapter-1`} class="btn btn-primary">
            เริ่มอ่าน
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href="#abstract" class="btn btn-ghost">ดูบทคัดย่อ</a>
        </div>

        <dl class="mt-10 sm:mt-12 grid grid-cols-3 gap-3 sm:gap-4 max-w-md">
          <div class="card p-3 sm:p-4">
            <dt class="text-[10px] sm:text-[11px] font-mono uppercase tracking-wider text-zinc-500">รูปแบบ</dt>
            <dd class="mt-1 text-sm sm:text-base font-semibold">กึ่งทดลอง</dd>
          </div>
          <div class="card p-3 sm:p-4">
            <dt class="text-[10px] sm:text-[11px] font-mono uppercase tracking-wider text-zinc-500">ตัวอย่าง</dt>
            <dd class="mt-1 text-sm sm:text-base font-semibold tnum">20–44</dd>
          </div>
          <div class="card p-3 sm:p-4">
            <dt class="text-[10px] sm:text-[11px] font-mono uppercase tracking-wider text-zinc-500">ภาพ</dt>
            <dd class="mt-1 text-sm sm:text-base font-semibold tnum">7 ภาพ</dd>
          </div>
        </dl>
      </div>

      <div class="relative hidden lg:block">
        <OrbitScene />
      </div>
    </div>
  </div>
</section>
