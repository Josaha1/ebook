---
const { number, title, subtitle, eyebrow = 'บทที่' } = Astro.props;
---
<header class="relative min-h-[60vh] flex items-end pb-14 pt-28 md:pt-36 px-6 overflow-hidden">
  <div class="absolute inset-0 -z-10 ar-gradient-radial opacity-60"></div>
  <div class="absolute top-10 right-0 w-72 h-72 rounded-full ar-gradient opacity-20 blur-3xl"></div>

  <div class="max-w-4xl mx-auto w-full">
    <p class="text-sm uppercase tracking-[0.3em] text-ar-pink font-semibold">{eyebrow}</p>
    <div class="text-[8rem] md:text-[12rem] leading-[0.85] font-black ar-gradient-text -ml-1 -mb-3 select-none">{number}</div>
    <h1 class="mt-2 text-3xl md:text-5xl font-bold leading-tight">{title}</h1>
    {subtitle && <p class="mt-4 text-base md:text-lg text-slate-600 dark:text-slate-300 max-w-2xl">{subtitle}</p>}
  </div>
</header>
