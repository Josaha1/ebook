---
const { number, title, subtitle, meta = [] } = Astro.props;
---
<header class="relative border-b hairline brand-gradient-subtle">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 sm:pt-28 md:pt-36 pb-12 md:pb-16">
    <span class="kicker">
      <span class="font-mono">Ch.</span>
      {typeof number === 'number' ? number : parseInt(number) || number}
    </span>

    <h1 class="mt-6 font-semibold leading-[1.15] tracking-tight"
      style="font-size: clamp(1.875rem, 4.5vw, 3rem);">
      {title}
    </h1>

    {subtitle && (
      <p class="mt-5 text-base md:text-lg leading-[1.75] text-zinc-600 dark:text-zinc-400 max-w-2xl">
        {subtitle}
      </p>
    )}

    {meta.length > 0 && (
      <dl class="mt-8 md:mt-10 flex flex-wrap gap-2">
        {meta.map((m: any) => (
          <div class="chip">
            <span class="text-zinc-500">{m.label}</span>
            <span class="font-semibold tnum">{m.value}</span>
          </div>
        ))}
      </dl>
    )}
  </div>
</header>
