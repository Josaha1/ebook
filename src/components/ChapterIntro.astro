---
const { number, title, subtitle, meta = [], kicker = 'Chapter' } = Astro.props;
---
<header class="relative min-h-[70vh] chapter-opener flex items-center overflow-hidden">
  <div class="absolute inset-0 opacity-[0.05]" aria-hidden="true"
    style="background-image: radial-gradient(rgba(245,239,228,0.5) 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="relative max-w-5xl mx-auto px-6 md:px-10 w-full py-24 md:py-32">
    <div class="eyebrow text-gold" style="color: #B8954A;">{kicker} · บทที่ {parseInt(number)}</div>

    <div class="mt-14 grid md:grid-cols-[auto_1fr] gap-10 md:gap-16 items-end">
      <div class="display-num italic text-gold leading-[0.78] text-[8rem] md:text-[11rem] lg:text-[13rem] select-none">{number}</div>
      <div class="pb-4 md:pb-8">
        <h1 class="font-display italic text-4xl md:text-6xl lg:text-[4rem] font-normal leading-[1.08]">{title}</h1>
        {subtitle && <p class="mt-6 font-serif text-base md:text-lg lg:text-xl leading-[1.75] text-cream/75 max-w-2xl">{subtitle}</p>}
      </div>
    </div>

    {meta.length > 0 && (
      <>
        <div class="mt-14 gold-line w-32"></div>
        <dl class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-8">
          {meta.map((m: any) => (
            <div>
              <dt class="text-[10px] uppercase tracking-[0.3em] text-gold font-sans font-semibold">{m.label}</dt>
              <dd class="mt-2 font-display italic text-lg md:text-xl tnum">{m.value}</dd>
            </div>
          ))}
        </dl>
      </>
    )}
  </div>
</header>
