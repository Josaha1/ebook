---
const { number, title, subtitle, meta = [] } = Astro.props;
---
<header class="relative border-b border-slate-200 dark:border-slate-800">
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute inset-0 bg-gradient-to-b from-[#FBF8F3] to-white dark:from-[#0C0A14] dark:to-slate-950"></div>
    <div class="absolute top-0 right-0 w-1/3 h-full ar-gradient opacity-[0.05]"></div>
  </div>

  <div class="max-w-5xl mx-auto px-6 pt-28 md:pt-36 pb-16">
    <div class="title-eyebrow"><span class="h-px w-10 bg-current opacity-40"></span>บทที่ {parseInt(number)} · Chapter {parseInt(number)}</div>
    <div class="mt-10 grid md:grid-cols-[auto_1fr] gap-10 md:gap-14 items-end">
      <div class="display-num text-[6rem] md:text-[9rem] leading-[0.8] ar-gradient-text select-none">{number}</div>
      <div>
        <h1 class="font-serif text-3xl md:text-5xl font-bold leading-[1.2]">{title}</h1>
        {subtitle && <p class="mt-5 text-lg text-slate-600 dark:text-slate-300 leading-[1.8] font-serif max-w-2xl">{subtitle}</p>}
      </div>
    </div>
    {meta.length > 0 && (
      <dl class="mt-10 grid grid-cols-2 sm:grid-cols-4 divide-x divide-slate-300 dark:divide-slate-700 border-y border-slate-300 dark:border-slate-700 py-4">
        {meta.map((m: any) => (
          <div class="px-4 sm:px-6 first:pl-0">
            <dt class="text-[10px] uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400 font-semibold">{m.label}</dt>
            <dd class="mt-1.5 font-serif font-bold text-base md:text-lg tnum">{m.value}</dd>
          </div>
        ))}
      </dl>
    )}
  </div>
</header>
