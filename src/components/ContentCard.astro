---
const { title, icon, accent = 'from-ar-purple to-ar-pink' } = Astro.props;
---
<div class="group relative rounded-3xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50 p-6 md:p-8 overflow-hidden transition hover:border-transparent hover:shadow-xl hover:shadow-pink-500/10">
  <div class={`absolute -top-20 -right-20 w-48 h-48 rounded-full bg-gradient-to-br ${accent} opacity-0 group-hover:opacity-20 blur-3xl transition-opacity`}></div>
  <div class="relative">
    {icon && (
      <div class={`inline-flex w-12 h-12 rounded-2xl items-center justify-center text-white text-xl ar-gradient mb-4 shadow-lg shadow-pink-500/20`}>
        {icon}
      </div>
    )}
    {title && <h3 class="text-xl md:text-2xl font-bold mb-3">{title}</h3>}
    <div class="text-slate-700 dark:text-slate-300 leading-relaxed text-sm md:text-base"><slot /></div>
  </div>
</div>
