---
const { items, current = 1, total = 3 } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<aside class="hidden lg:block sticky top-24 self-start">
  <div class="border-l border-slate-300 dark:border-slate-700 pl-0">
    <div class="pl-5">
      <div class="title-eyebrow text-[10px]">บทที่ {current} · {total}</div>
      <div class="mt-3 flex gap-1 items-center">
        {Array.from({ length: total }).map((_, i) => (
          <div class={`h-1 flex-1 rounded-full ${i < current ? 'ar-gradient' : 'bg-slate-200 dark:bg-slate-800'}`}></div>
        ))}
      </div>
    </div>

    <nav class="mt-6">
      <div class="pl-5 text-[10px] font-sans font-semibold text-slate-500 dark:text-slate-400 mb-2 uppercase tracking-[0.25em]">ในบทนี้</div>
      <ul id="chapter-toc">
        {items.map((it: any) => (
          <li><a href={`#${it.id}`} class="toc-link" data-toc-link={it.id}>{it.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="mt-6 pl-5 pt-5 border-t border-slate-200 dark:border-slate-800 flex flex-col gap-2 text-sm font-sans">
      {current > 1 && <a href={`${base}/chapter-${current - 1}`} class="text-slate-500 dark:text-slate-400 hover:text-purple-700">← บทที่ {current - 1}</a>}
      {current < total && <a href={`${base}/chapter-${current + 1}`} class="text-purple-700 dark:text-purple-300 font-semibold">บทที่ {current + 1} →</a>}
      {current === total && <a href={`${base}/`} class="text-slate-500 dark:text-slate-400 hover:text-purple-700">← หน้าหลัก</a>}
    </div>
  </div>
</aside>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  if (links.length) {
    const targets = Array.from(links).map((a) => ({ id: a.dataset.tocLink!, link: a, el: document.getElementById(a.dataset.tocLink!) })).filter((t) => t.el);
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          links.forEach((a) => a.classList.remove('active'));
          const match = targets.find((t) => t.el === e.target);
          match?.link.classList.add('active');
        }
      }
    }, { rootMargin: '-15% 0px -70% 0px' });
    targets.forEach((t) => io.observe(t.el!));
  }
</script>
