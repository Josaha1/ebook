---
const { items, current = 1, total = 3 } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<aside class="hidden lg:block sticky top-24 self-start">
  <div class="eyebrow mb-4" style="color: #B8954A;">Chapter {current} of {total}</div>
  <div class="flex gap-1 mb-8">
    {Array.from({ length: total }).map((_, i) => (
      <div class={`h-[2px] flex-1 ${i < current ? 'bg-gold' : 'bg-sepia/25'}`}></div>
    ))}
  </div>

  <nav>
    <div class="text-[10px] font-sans font-semibold text-sepia mb-3 uppercase tracking-[0.3em]">Contents</div>
    <ul id="chapter-toc" class="border-t hairline">
      {items.map((it: any) => (
        <li><a href={`#${it.id}`} class="toc-link" data-toc-link={it.id}><span>{it.label}</span></a></li>
      ))}
    </ul>
  </nav>

  <div class="mt-8 pt-6 border-t hairline flex flex-col gap-2 text-sm font-serif italic">
    {current > 1 && <a href={`${base}/chapter-${current - 1}`} class="text-sepia hover:text-gold">← Previous chapter</a>}
    {current < total && <a href={`${base}/chapter-${current + 1}`} class="text-gold hover:text-burgundy">Next chapter →</a>}
    {current === total && <a href={`${base}/`} class="text-sepia hover:text-gold">← Return home</a>}
  </div>
</aside>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  if (links.length) {
    const targets = Array.from(links).map((a) => ({ id: a.dataset.tocLink!, link: a, el: document.getElementById(a.dataset.tocLink!) })).filter((t) => t.el);
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          links.forEach((a) => a.classList.remove('active'));
          const match = targets.find((t) => t.el === e.target);
          match?.link.classList.add('active');
        }
      }
    }, { rootMargin: '-15% 0px -70% 0px' });
    targets.forEach((t) => io.observe(t.el!));
  }
</script>
