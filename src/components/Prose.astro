---
const { class: className = '' } = Astro.props;
---
<div class:list={['prose-th', className]}><slot /></div>

<style is:global>
  .prose-th { line-height: 1.85; color: #334155; }
  .prose-th p { margin-bottom: 1.2em; font-size: 1.02rem; }
  .prose-th p:first-child::first-letter {
    font-size: 3rem; font-weight: 700; float: left; line-height: 0.95; padding: 0.1em 0.15em 0 0;
    background: linear-gradient(135deg, #7C3AED, #EC4899, #F97316);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  html.dark .prose-th { color: #cbd5e1; }
  .prose-th strong { color: #0f172a; font-weight: 600; }
  html.dark .prose-th strong { color: #f8fafc; }
</style>
