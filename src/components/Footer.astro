---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---
<footer class="mt-24 border-t hairline">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid md:grid-cols-[1.4fr_1fr_1fr] gap-10">
      <div>
        <div class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-lg brand-gradient grid place-items-center text-white text-xs font-bold">AR</div>
          <span class="font-semibold text-lg">E-Book</span>
        </div>
        <p class="mt-4 text-sm md:text-base text-zinc-600 dark:text-zinc-400 leading-relaxed max-w-md">
          ผลการให้ข้อมูลผู้รับบริการโรงพยาบาลนภาลัย จังหวัดสมุทรสงคราม ด้วยสื่อมือถือผ่านเทคโนโลยี Augmented Reality
        </p>
        <div class="mt-4 text-xs font-mono uppercase tracking-wider text-zinc-500">
          เมษายน – สิงหาคม 2560
        </div>
      </div>
      <div>
        <div class="text-[11px] font-mono uppercase tracking-wider text-zinc-500 mb-3">สารบัญ</div>
        <ul class="space-y-2 text-sm">
          <li><a href={`${base}/chapter-1`} class="hover:text-indigo-600 dark:hover:text-indigo-400 transition">บทที่ 1 · บทนำ</a></li>
          <li><a href={`${base}/chapter-2`} class="hover:text-indigo-600 dark:hover:text-indigo-400 transition">บทที่ 2 · วรรณกรรมและงานวิจัย</a></li>
          <li><a href={`${base}/chapter-3`} class="hover:text-indigo-600 dark:hover:text-indigo-400 transition">บทที่ 3 · วิธีดำเนินการวิจัย</a></li>
        </ul>
      </div>
      <div>
        <div class="text-[11px] font-mono uppercase tracking-wider text-zinc-500 mb-3">แชร์</div>
        <div class="flex flex-col gap-2 text-sm">
          <button id="share-copy" class="text-left text-zinc-600 dark:text-zinc-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition">คัดลอกลิงก์</button>
          <a id="share-fb" target="_blank" rel="noopener" class="text-zinc-600 dark:text-zinc-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition">Facebook</a>
          <a id="share-line" target="_blank" rel="noopener" class="text-zinc-600 dark:text-zinc-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition">LINE</a>
        </div>
      </div>
    </div>

    <div class="mt-10 md:mt-12 pt-6 border-t hairline flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 text-xs text-zinc-500">
      <div>© {year} · เผยแพร่เพื่อการศึกษาและนำเสนอทางวิชาการ</div>
      <div class="font-mono">Set in IBM Plex Sans Thai</div>
    </div>
  </div>
</footer>
<button id="to-top" aria-label="กลับด้านบน"
  class="fixed bottom-4 right-4 lg:bottom-6 lg:right-6 w-11 h-11 rounded-full btn-primary shadow-xl opacity-0 pointer-events-none transition-opacity z-30 grid place-items-center">
  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
</button>
<script>
  const copyBtn = document.getElementById('share-copy');
  const fb = document.getElementById('share-fb') as HTMLAnchorElement | null;
  const line = document.getElementById('share-line') as HTMLAnchorElement | null;
  const url = typeof window !== 'undefined' ? window.location.href : '';
  if (fb) fb.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
  if (line) line.href = `https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(url)}`;
  copyBtn?.addEventListener('click', async () => {
    try { await navigator.clipboard.writeText(window.location.href); copyBtn.textContent = '✓ คัดลอกแล้ว'; setTimeout(() => copyBtn.textContent = 'คัดลอกลิงก์', 1500); } catch {}
  });
  const toTop = document.getElementById('to-top');
  if (toTop) {
    window.addEventListener('scroll', () => {
      const show = window.scrollY > 600;
      toTop.style.opacity = show ? '1' : '0';
      toTop.style.pointerEvents = show ? 'auto' : 'none';
    }, { passive: true });
    toTop.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  }
</script>
