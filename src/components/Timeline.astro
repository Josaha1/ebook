---
const { items } = Astro.props;
---
<ol class="relative ml-5 md:ml-6 border-l-2 border-dashed border-ar-pink/40">
  {items.map((it: any, i: number) => (
    <li class="sr-el relative pl-8 md:pl-10 pb-12 last:pb-0">
      <span class="absolute -left-[1.1rem] md:-left-[1.25rem] top-0 flex items-center justify-center w-9 h-9 md:w-10 md:h-10 rounded-full ar-gradient text-white font-bold text-sm shadow-lg shadow-pink-500/30 ring-4 ring-white dark:ring-slate-950">
        {it.step ?? i + 1}
      </span>
      <div class="rounded-2xl p-5 md:p-6 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/40">
        {it.label && <p class="text-xs uppercase tracking-widest text-ar-pink font-semibold mb-1">{it.label}</p>}
        <h3 class="text-lg md:text-xl font-bold">{it.title}</h3>
        {it.description && <p class="mt-2 text-sm md:text-base text-slate-600 dark:text-slate-300 leading-relaxed">{it.description}</p>}
        {it.points && (
          <ul class="mt-3 space-y-1.5 text-sm text-slate-700 dark:text-slate-300">
            {it.points.map((p: string) => (
              <li class="flex gap-2"><span class="text-ar-pink">•</span><span>{p}</span></li>
            ))}
          </ul>
        )}
      </div>
    </li>
  ))}
</ol>
