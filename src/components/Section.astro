---
const { num, title, anchor } = Astro.props;
const id = anchor ?? (num ? `section-${String(num).replace(/\./g, '-')}` : undefined);
---
<section id={id} class="scroll-mt-20">
  {title && (
    <div class="mb-6 md:mb-8">
      {num && <div class="kicker mb-3">Section {num}</div>}
      <h2 class="font-semibold"
        style="font-size: clamp(1.5rem, 3.5vw, 2rem); line-height: 1.4; letter-spacing: 0;">
        {title}
      </h2>
    </div>
  )}
  <div class="prose-mod"><slot /></div>
</section>
