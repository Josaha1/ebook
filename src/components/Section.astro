---
const { num, title, anchor } = Astro.props;
const id = anchor ?? (num ? `section-${String(num).replace(/\./g, '-')}` : undefined);
---
<section id={id} class="scroll-mt-24">
  {title && (
    <div class="mb-8">
      <h2 class="font-serif text-2xl md:text-[1.75rem] font-bold leading-tight">
        {num && <span class="section-num mr-3">{num}</span>}
        <span>{title}</span>
      </h2>
      <div class="mt-3 h-px bg-slate-300 dark:bg-slate-700 max-w-[4rem]"></div>
    </div>
  )}
  <div class="prose-academic"><slot /></div>
</section>
