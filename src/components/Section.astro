---
const { num, title, anchor } = Astro.props;
const id = anchor ?? (num ? `section-${String(num).replace(/\./g, '-')}` : undefined);
---
<section id={id} class="scroll-mt-24">
  {title && (
    <div class="mb-10">
      {num && <div class="eyebrow mb-4" style="color: #B8954A;">Section {num}</div>}
      <h2 class="font-display italic text-3xl md:text-4xl lg:text-[2.5rem] font-normal leading-[1.18]">{title}</h2>
    </div>
  )}
  <div class="prose-ct"><slot /></div>
</section>
