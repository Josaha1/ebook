---
const { size = 180, label = 'AR' } = Astro.props;
const half = size / 2;
---
<div class="scene-3d inline-block" style={`width:${size}px; height:${size}px;`}>
  <div class="ar-cube w-full h-full">
    <div class="face" style={`transform: translateZ(${half}px);`}>{label}</div>
    <div class="face" style={`transform: rotateY(180deg) translateZ(${half}px);`}>3D</div>
    <div class="face" style={`transform: rotateY(90deg) translateZ(${half}px);`}>XR</div>
    <div class="face" style={`transform: rotateY(-90deg) translateZ(${half}px);`}>VR</div>
    <div class="face" style={`transform: rotateX(90deg) translateZ(${half}px);`}>◈</div>
    <div class="face" style={`transform: rotateX(-90deg) translateZ(${half}px);`}>◆</div>
  </div>
</div>
