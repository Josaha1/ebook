---
const { src, alt, caption, number, maxW = 'max-w-2xl' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const full = src.startsWith('http') ? src : `${base}${src.startsWith('/') ? '' : '/'}${src}`;
---
<figure class={`my-12 mx-auto ${maxW}`}>
  <div class="paper-flat rounded-sm overflow-hidden">
    <img src={full} alt={alt} loading="lazy" class="w-full h-auto" />
  </div>
  {(number || caption) && (
    <figcaption class="figure-caption">
      {number && <span class="font-bold not-italic text-slate-900 dark:text-slate-100 smallcaps">ภาพที่&nbsp;{number}</span>}
      {number && caption && <span class="mx-2">·</span>}
      {caption}
    </figcaption>
  )}
</figure>
