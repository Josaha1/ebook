---
const { src, alt, caption, number, maxW = 'max-w-2xl' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const full = src.startsWith('http') ? src : `${base}${src.startsWith('/') ? '' : '/'}${src}`;
---
<figure class={`my-10 md:my-12 mx-auto ${maxW}`}>
  <div class="card overflow-hidden rounded-xl">
    <img src={full} alt={alt} loading="lazy" class="w-full h-auto block" />
  </div>
  {(number || caption) && (
    <figcaption class="figure-caption">
      {number && <span class="font-mono font-medium not-italic text-indigo-600 dark:text-indigo-400">ภาพที่ {number}</span>}
      {number && caption && <span class="mx-1.5 text-zinc-400">·</span>}
      {caption}
    </figcaption>
  )}
</figure>
