---
const { size = 96 } = Astro.props;
---
<div class="relative inline-block" style={`width:${size}px; height:${size}px;`}>
  <span class="absolute inset-0 rounded-full ar-gradient opacity-30 pulse-ring"></span>
  <div class="relative w-full h-full rounded-2xl ar-gradient grid place-items-center shadow-xl">
    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[55%] h-[55%]">
      <path d="M3 13h4l2-5 4 10 2-5h6"/>
    </svg>
  </div>
</div>
