---
const { cite } = Astro.props;
---
<blockquote class="my-8 relative pl-6 border-l-4 border-purple-600 dark:border-purple-400 py-2">
  <div class="text-lg md:text-xl leading-relaxed text-slate-800 dark:text-slate-200 font-medium"><slot /></div>
  {cite && <cite class="block mt-3 text-sm text-slate-500 dark:text-slate-400 not-italic">— {cite}</cite>}
</blockquote>
