---
const { cite } = Astro.props;
---
<figure class="my-12 md:my-16">
  <div class="relative">
    <div class="absolute -top-2 left-0 text-6xl md:text-7xl brand-gradient-text leading-none select-none opacity-80" aria-hidden="true">"</div>
    <blockquote class="pl-12 md:pl-16 font-medium leading-[1.35] tracking-tight text-zinc-900 dark:text-zinc-50"
      style="font-size: clamp(1.375rem, 3vw, 1.875rem);">
      <slot />
    </blockquote>
  </div>
  {cite && <figcaption class="mt-5 pl-12 md:pl-16 text-xs font-mono uppercase tracking-wider text-zinc-500">— {cite}</figcaption>}
</figure>
