---
const { cite } = Astro.props;
---
<blockquote class="my-10 relative py-5 px-8 border-l-[3px] border-purple-700 dark:border-purple-400">
  <div class="font-serif text-xl md:text-2xl leading-[1.6] text-slate-900 dark:text-slate-100 font-medium italic"><slot /></div>
  {cite && <cite class="block mt-4 text-sm text-slate-500 dark:text-slate-400 not-italic font-sans">— {cite}</cite>}
</blockquote>
