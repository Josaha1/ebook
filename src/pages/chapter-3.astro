---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChapterIntro from '../components/ChapterIntro.astro';
import ChapterSidebar from '../components/ChapterSidebar.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import Section from '../components/Section.astro';
import Pullquote from '../components/Pullquote.astro';
import Phone3D from '../components/Phone3D.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const toc = [
  { id: 'section-overview', label: 'ภาพรวม' },
  { id: 'section-3-1', label: '3.1 ขั้นเตรียมการ' },
  { id: 'section-3-2', label: '3.2 ขั้นดำเนินการ' },
  { id: 'section-3-3', label: '3.3 สรุปประเมินผล' },
  { id: 'section-3-4', label: '3.4 การพิทักษ์สิทธิ์' },
];
---
<BaseLayout title="บทที่ 3 · วิธีดำเนินการวิจัย · AR E-Book">
  <ChapterIntro
    number={3}
    title="วิธีดำเนินการวิจัย"
    subtitle="การออกแบบการศึกษากึ่งทดลอง กลุ่มตัวอย่าง เครื่องมือที่ใช้ และการพิทักษ์สิทธิ์ผู้เข้าร่วมการศึกษา"
    meta={[
      { label: 'หน้า', value: '2 หน้า' },
      { label: 'คำ', value: '525 คำ' },
      { label: 'ตัวอย่าง', value: '44 ราย' },
    ]}
  />

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
    <div class="grid lg:grid-cols-[220px_1fr] gap-10 lg:gap-16">
      <ChapterSidebar items={toc} current={3} />

      <div class="min-w-0 space-y-16 md:space-y-20">
        <ScrollReveal>
          <Section anchor="section-overview">
            <p>
              การศึกษาเรื่อง <strong>"ผลการให้ข้อมูลผู้รับบริการโรงพยาบาลนภาลัย จังหวัดสมุทรสงคราม ด้วยสื่อมือถือ"</strong> เป็นการศึกษาแบบ<strong>กึ่งทดลอง</strong> โดยศึกษาการใช้สื่อการให้ข้อมูลผู้รับบริการ โรงพยาบาลนภาลัย ตำบลกระดังงา จังหวัดสมุทรสงคราม จำนวน <strong>20–30 ราย</strong> โดยใช้สื่อแอพพลิเคชันในมือถือ รายละเอียดของวิธีดำเนินการศึกษามีดังนี้
            </p>
          </Section>
        </ScrollReveal>

        <ScrollReveal>
          <Section num="3.1" title="ขั้นเตรียมการ" anchor="section-3-1">
            <div class="not-prose space-y-4">
              <div class="card p-5 md:p-6">
                <div class="flex items-baseline gap-3 mb-3">
                  <span class="section-num">3.1.1</span>
                  <h3 class="font-semibold text-lg md:text-xl">ค้นหาปัญหา</h3>
                </div>
                <p class="prose-mod">
                  พบว่าเดิมการให้คำแนะนำ การสอนผู้ดูแลให้กลับไปปฏิบัติตนที่บ้านเราใช้เอกสารซึ่งเป็นกระดาษเป็นหลัก การเก็บเอกสารกลับบ้านมีปัญหาชำรุด จำไม่ได้ อาจต้องนำมาอ่านดูซ้ำซึ่งบางรายสูญหายไปแล้ว หรืออ่านแล้วไม่เข้าใจ
                </p>
              </div>
              <div class="card p-5 md:p-6">
                <div class="flex items-baseline gap-3 mb-3">
                  <span class="section-num">3.1.2</span>
                  <h3 class="font-semibold text-lg md:text-xl">ศึกษานวัตกรรมการสอนอื่น</h3>
                </div>
                <p class="prose-mod">
                  เพื่อการให้ข้อมูล มาใช้ในการให้ข้อมูลผู้รับบริการในโรงพยาบาลนภาลัย โดยใช้หลัก <strong>สะดวก เข้าถึงข้อมูลง่าย ทันกับยุคสมัยปัจจุบัน ลดต้นทุนในการผลิตสื่อ</strong> ซึ่งผู้ศึกษาได้ใช้สื่อมือถือและคัดเลือกแอพพลิเคชันในมือถือมา 2 แบบ ได้แก่
                </p>
                <div class="mt-4 grid sm:grid-cols-2 gap-3">
                  <div class="rounded-xl p-4 brand-gradient-subtle flex items-center gap-3">
                    <div class="w-10 h-10 rounded-lg brand-gradient text-white font-mono text-xs grid place-items-center font-bold">AR</div>
                    <div>
                      <div class="font-semibold">Aurasma</div>
                      <div class="text-xs text-zinc-500">Augmented Reality</div>
                    </div>
                  </div>
                  <div class="rounded-xl p-4 bg-green-500/5 flex items-center gap-3">
                    <div class="w-10 h-10 rounded-lg bg-green-600 text-white font-mono text-xs grid place-items-center font-bold">QR</div>
                    <div>
                      <div class="font-semibold">QR code LINE</div>
                      <div class="text-xs text-zinc-500">Scan & Go</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </Section>
        </ScrollReveal>

        <ScrollReveal>
          <Section num="3.2" title="ขั้นดำเนินการ" anchor="section-3-2">
            <div class="not-prose space-y-5">
              <div class="card p-5 md:p-7">
                <div class="flex items-baseline gap-3 mb-3">
                  <span class="section-num">3.2.1</span>
                  <h3 class="font-semibold text-lg md:text-xl">ปรับเนื้อหาให้ทันสมัย</h3>
                </div>
                <p class="prose-mod">
                  นำเอกสารหรือข้อมูลคำแนะนำการปฏิบัติตนที่มีใช้ในโรงพยาบาลนภาลัยมาปรับให้ทันสมัย ถูกต้องตามหลักวิชาการปัจจุบัน โดยในระยะแรกเริ่มทำในกลุ่มโรคที่ผู้ศึกษาได้ทำการศึกษาและผลิตสื่อแผ่นพับ คู่มือการปฏิบัติตนต่างๆ ได้แก่
                </p>
                <ul class="mt-4 space-y-2">
                  <li class="flex gap-2"><span class="text-indigo-600">—</span><span>การดูแลผู้ป่วยที่ช่วยเหลือตนเองได้น้อยเพื่อป้องกันโรคแทรกซ้อน เช่น แผลกดทับ</span></li>
                  <li class="flex gap-2"><span class="text-indigo-600">—</span><span>การดูแลแผลเรื้อรังและอุปกรณ์ต่อพ่วง</span></li>
                  <li class="flex gap-2"><span class="text-indigo-600">—</span><span>การดูแลผู้ป่วยมะเร็ง</span></li>
                </ul>
                <p class="prose-mod mt-4">
                  ค้นหาคัดเลือกภาพนิ่งหรือภาพเคลื่อนไหว Clip VDO ในฐานข้อมูลอิเล็กทรอนิกส์ นำไปให้ผู้เชี่ยวชาญแต่ละสาขาวิชาตรวจความตรง ความถูกต้องและความเที่ยง แล้วนำข้อมูลมาปรับเปลี่ยนเป็นภาพหรือสื่อมีเดียต่างๆ เตรียมผลิตเป็นสื่อการให้ข้อมูลผู้รับบริการทางการพยาบาลโดยใช้สื่อเทคโนโลยีเรียนรู้ผ่านสื่อบนมือถือ
                </p>
                <p class="prose-mod mt-3">
                  ผู้ศึกษาคัดเลือกเนื้อหาจากผลงานของตนเองที่ทำการศึกษาวิจัยจากงานประจำที่ปฏิบัติอยู่ในปี พ.ศ. 2556 ถึง พ.ศ. 2559 อันได้แก่
                </p>
                <div class="mt-4 grid sm:grid-cols-2 gap-2">
                  <div class="chip text-xs">คู่มือการดูแลผู้ป่วยแผลเรื้อรัง</div>
                  <div class="chip text-xs">คู่มือผู้ป่วยมะเร็งระยะแพร่กระจาย</div>
                  <div class="chip text-xs">การจัดการความปวดในผู้ป่วยมะเร็ง</div>
                  <div class="chip text-xs">ฐานข้อมูลจุฬาลงกรณ์มหาวิทยาลัย</div>
                </div>
              </div>

              <div class="card p-5 md:p-7">
                <div class="flex items-baseline gap-3 mb-3">
                  <span class="section-num">3.2.2</span>
                  <h3 class="font-semibold text-lg md:text-xl">สร้างสื่อด้วย Aurasma + QR LINE</h3>
                </div>
                <p class="prose-mod">
                  สร้างสื่อการให้ข้อมูลหรือการสอนโดยใช้แอพพลิเคชัน <strong>Aurasma</strong> และ <strong>QR code LINE</strong>
                </p>
                <div class="mt-6 grid sm:grid-cols-2 gap-6 items-center">
                  <div class="flex justify-center"><Phone3D variant="ar" /></div>
                  <div class="flex justify-center"><Phone3D variant="qr" /></div>
                </div>
              </div>

              <div class="card p-5 md:p-7">
                <div class="flex items-baseline gap-3 mb-3">
                  <span class="section-num">3.2.3</span>
                  <h3 class="font-semibold text-lg md:text-xl">ทดลองใช้จริง</h3>
                </div>
                <Pullquote cite="ระหว่างเมษายน – สิงหาคม พ.ศ. 2560">ทดลองใช้กับผู้รับบริการ <em>จำนวน 44 ราย</em></Pullquote>

                <p class="prose-mod">โดยใช้เครื่องมือดังนี้</p>

                <ol class="mt-6 space-y-3">
                  {[
                    { n: 1, title: 'เอกสารให้ความรู้โรคแผลเรื้อรัง', desc: 'แผลกดทับ · แผลเบาหวาน · แผลผ่าตัดทวารหนักทางหน้าท้อง' },
                    { n: 2, title: 'คู่มือผู้ป่วยที่มีอุปกรณ์ต่อพ่วง', desc: 'สายให้อาหารทางสายยาง · สายสวนปัสสาวะ · ท่อหายใจที่คอ · คู่มือผู้ป่วยมะเร็งระยะแพร่กระจาย' },
                    { n: 3, title: 'แผ่นพับการจัดการความปวด', desc: 'การดูแลผู้ป่วยมะเร็ง · ป้องกันแผลกดทับ · ดูแลแผลเรื้อรัง' },
                    { n: 4, title: 'คลิปวีดีโอใน YouTube', desc: 'การให้อาหารสายยาง · เคลื่อนย้ายผู้ป่วยอัมพาตครึ่งซีก · ฟื้นฟูหลอดเลือดสมอง · ทำความสะอาดท่อหายใจที่คอ · ป้องกันแผลกดทับและเบาหวาน' },
                    { n: 5, title: 'อุปกรณ์การทดลอง', desc: 'โทรศัพท์มือถือ · iPad · iPhone' },
                    { n: 6, title: 'แบบประเมินผล', desc: '"ผลการให้ข้อมูลผู้รับบริการโรงพยาบาลนภาลัยโดยสื่อมือถือ"' },
                  ].map((it) => (
                    <li class="flex gap-4 p-4 rounded-xl bg-zinc-50 dark:bg-zinc-900/40">
                      <span class="flex-shrink-0 w-9 h-9 rounded-full brand-gradient text-white font-mono font-medium text-sm grid place-items-center tnum">{String(it.n).padStart(2, '0')}</span>
                      <div class="min-w-0">
                        <div class="font-semibold">{it.title}</div>
                        <div class="mt-1 text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">{it.desc}</div>
                      </div>
                    </li>
                  ))}
                </ol>
              </div>
            </div>
          </Section>
        </ScrollReveal>

        <ScrollReveal>
          <Section num="3.3" title="สรุป ประเมินผล" anchor="section-3-3">
            <p>
              สรุปและประเมินผลการให้ข้อมูลผู้รับบริการโรงพยาบาลนภาลัยด้วยสื่อมือถือ และความพึงพอใจ ด้วย<strong>แบบประเมินออนไลน์ผ่านการสแกน QR code</strong>
            </p>
            <div class="not-prose my-10 flex justify-center">
              <Phone3D variant="qr" />
            </div>
          </Section>
        </ScrollReveal>

        <ScrollReveal>
          <Section num="3.4" title="การพิทักษ์สิทธิ์" anchor="section-3-4">
            <div class="not-prose card p-6 md:p-8 brand-gradient-subtle">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full brand-gradient grid place-items-center text-white">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <p class="prose-mod">
                  เนื่องจากการศึกษานี้มีความเสี่ยงต่ออาสาสมัครน้อย ผู้ศึกษาได้เขียนบันทึกขออนุญาตผู้อำนวยการโรงพยาบาลเจ้าของสถานที่และได้รับอนุญาตให้ศึกษาได้ก่อนทำการศึกษาเมื่อ<strong>วันที่ 21 เมษายน 2560</strong> ผู้ที่กรอกแบบประเมินถือว่ายินยอมในการศึกษาในครั้งนี้
                </p>
              </div>
            </div>
          </Section>
        </ScrollReveal>

        <ScrollReveal>
          <nav class="pt-8 border-t hairline flex items-center justify-between gap-4 flex-wrap">
            <a href={`${base}/chapter-2`} class="text-sm text-zinc-500 hover:text-indigo-600 dark:hover:text-indigo-400">← บทที่ 2</a>
            <a href={`${base}/`} class="btn btn-ghost">
              กลับหน้าหลัก
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </nav>
        </ScrollReveal>
      </div>
    </div>
  </div>
</BaseLayout>
