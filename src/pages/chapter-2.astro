---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChapterIntro from '../components/ChapterIntro.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import ContentCard from '../components/ContentCard.astro';
import ARViewer from '../components/ARViewer.astro';
import Prose from '../components/Prose.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="บทที่ 2 · เอกสารที่เกี่ยวข้อง · AR E-Book">
  <ChapterIntro
    number="02"
    title="วรรณกรรมและงานวิจัยที่เกี่ยวข้อง"
    subtitle="ทำความเข้าใจกระบวนการสื่อสาร เทคโนโลยี AR, Aurasma และ QR code ก่อนลงมือใช้จริง"
  />

  <div class="max-w-5xl mx-auto px-6 py-16 md:py-20 space-y-20">

    <ScrollReveal>
      <section class="rounded-3xl ar-gradient p-[1px]">
        <div class="bg-white dark:bg-slate-950 rounded-3xl p-6 md:p-10">
          <p class="text-base md:text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
            การศึกษานี้เป็นการศึกษา<strong>กึ่งทดลอง</strong> ผู้ศึกษาได้ทำการศึกษาในผู้รับบริการโรงพยาบาลนภาลัย จังหวัดสมุทรสงคราม โดยทบทวนวรรณกรรมและงานวิจัยที่เกี่ยวข้องเพื่อใช้ในการศึกษา
          </p>
        </div>
      </section>
    </ScrollReveal>

    <ScrollReveal>
      <section>
        <h2 class="text-2xl md:text-3xl font-bold mb-6 flex items-center gap-3">
          <span class="w-10 h-1 rounded-full ar-gradient"></span>
          กระบวนการสื่อสาร
        </h2>
        <Prose>
          <p><strong>Communication Process</strong> เริ่มต้นจากผู้ส่งข่าวสารมีข่าวสารที่จะให้กับผู้รับ ซึ่งอาจเป็นข้อมูลที่เป็นความรู้ ความคิด หรือความรู้สึก โดยผู้ส่งเลือกวิธีที่จะส่ง เช่น การพูด การเขียน หรือการใช้ภาษาท่าทาง เมื่อผู้รับได้รับข่าวสารจะเกิดการส่งข้อมูลตอบกลับ เป็นกระบวนการที่ไม่อยู่นิ่งและมีความต่อเนื่องกัน</p>
          <p>การสื่อสารมีความสำคัญอย่างยิ่งต่อวิชาชีพพยาบาล กิจกรรมบทบาทอิสระของพยาบาลคือ การให้ข้อมูลเพื่อเอื้อให้เกิดการตัดสินใจที่ถูกต้อง เป็นที่ปรึกษาในการตัดสินใจเกี่ยวกับการดูแล การสอนผู้ป่วยและครอบครัว รูปแบบการสื่อสารจำเป็นต้องพัฒนาให้ทันสมัยตามวิวัฒนาการของเทคโนโลยี</p>
        </Prose>
      </section>
    </ScrollReveal>

    <ScrollReveal>
      <section class="grid md:grid-cols-2 gap-5">
        <ContentCard title="โทรศัพท์เคลื่อนที่" icon="📱" accent="from-ar-purple to-ar-pink">
          เทคโนโลยี Mobile Device พัฒนาอย่างรวดเร็ว สังเกตได้จากความสามารถที่มีมากขึ้นทั้งส่วนรับข้อมูล ส่วนต่อประสานกับผู้ใช้ ความบันเทิง และการเชื่อมต่อ
        </ContentCard>
        <ContentCard title="ระบบปฏิบัติการ" icon="⚙️" accent="from-ar-pink to-ar-orange">
          iOS และ Android ต่างพัฒนาเพื่อรองรับการทำงานของเทคโนโลยีใหม่ๆ เปิดทางให้แอปพลิเคชันด้านการศึกษาและสุขภาพเข้าถึงผู้คนได้มากขึ้น
        </ContentCard>
      </section>
    </ScrollReveal>

    <ScrollReveal>
      <section>
        <div class="mb-8">
          <p class="text-sm uppercase tracking-widest text-ar-pink font-semibold">เทคโนโลยี #1</p>
          <h2 class="mt-2 text-3xl md:text-4xl font-bold">QR Code ใน LINE</h2>
          <p class="mt-3 text-slate-600 dark:text-slate-400 max-w-2xl">บาร์โค้ด 2 มิติที่เก็บข้อมูลได้มากกว่าบาร์โค้ดแบบแท่ง สแกนได้ทันทีด้วยกล้องมือถือ</p>
        </div>

        <div class="grid md:grid-cols-3 gap-5 mb-8">
          <ContentCard title="Quick Response" icon="⚡" accent="from-ar-purple to-ar-pink">
            ย่อมาจาก <strong>Quick Response Code</strong> — ออกแบบให้อ่านได้อย่างรวดเร็ว
          </ContentCard>
          <ContentCard title="2 มิติ" icon="▦" accent="from-ar-pink to-ar-orange">
            บาร์โค้ด 2D ประกอบด้วยมอดูลสีดำเรียงตัวในสัณฐานสี่เหลี่ยม บนพื้นหลังขาว
          </ContentCard>
          <ContentCard title="ต้นกำเนิด" icon="🏭" accent="from-ar-purple to-ar-orange">
            พัฒนาโดย <strong>Denso-Wave</strong> บริษัทในเครือ Toyota ประเทศญี่ปุ่น ในปี 1994
          </ContentCard>
        </div>

        <Prose>
          <p>QR code นำมาใช้เก็บข้อมูล URL, ข้อความ, เบอร์โทรศัพท์ และข้อมูลตัวอักษรอื่นๆ ความนิยมเพิ่มขึ้นเรื่อยๆ เพราะใช้งานง่าย ไม่ต้องใช้เครื่องอ่านเฉพาะทาง แค่สมาร์ทโฟนที่มีกล้องก็อ่านค่าที่ซ่อนอยู่ได้ทันที — <strong>ไม่ต้องพิมพ์ URL ที่ยาวและอาจพิมพ์ผิด</strong></p>
        </Prose>
      </section>
    </ScrollReveal>

    <ScrollReveal>
      <section>
        <h3 class="text-xl md:text-2xl font-bold mb-5 flex items-center gap-3">
          <span class="w-8 h-1 rounded-full ar-gradient"></span>
          ตัวอย่างการประยุกต์ใช้ QR code
        </h3>
        <div class="grid md:grid-cols-2 gap-5">
          <ContentCard title="LIMS — ห้องปฏิบัติการวิทยาศาสตร์" accent="from-ar-purple to-ar-pink">
            Laboratory Information Management System ของมหาวิทยาลัยสงขลานครินทร์ (ชีวิน ชนะวรรโณ, 2557) ระบบอัตโนมัติครอบคลุมตั้งแต่ขั้นรับ-ส่งตัวอย่างจากผู้ใช้บริการ การทดสอบและวิเคราะห์
          </ContentCard>
          <ContentCard title="ตรวจสอบย้อนกลับผักสด" accent="from-ar-pink to-ar-orange">
            ระบบตรวจสอบย้อนกลับในการส่งออกผักสด (จิรพร ซื่อจริง, 2555) ตรวจแหล่งที่มาได้ตั้งแต่ฟาร์ม โรงคัดบรรจุ ถึงการขนส่ง สร้างความมั่นใจให้ผู้บริโภค
          </ContentCard>
          <ContentCard title="นิทรรศการม.แม่โจ้" accent="from-ar-orange to-ar-purple">
            คณะสารสนเทศและการสื่อสาร ม.แม่โจ้ ใช้ QR code ในบอร์ดนิทรรศการเพื่อเชื่อมไปยังเว็บไซต์ ทำให้ผู้ชมเห็นภาพ วิดีโอ และข้อมูลเพิ่มเติมได้
          </ContentCard>
          <ContentCard title="ด้านการพยาบาล" accent="from-ar-purple to-ar-pink">
            การประยุกต์ใช้ QR code ในโรงพยาบาลนภาลัย เชื่อมโยงไปยังสื่อวิดีโอและเนื้อหาแนะนำการดูแลตนเองของผู้ป่วย
          </ContentCard>
        </div>
      </section>
    </ScrollReveal>

    <ScrollReveal>
      <ARViewer
        src="models/robot.glb"
        alt="Robot 3D demo"
        caption="ตัวอย่างโมเดล 3D · ทดลองหมุน ซูม และส่อง AR ได้"
        orbit="-20deg 70deg 6m"
      />
    </ScrollReveal>

    <ScrollReveal>
      <section>
        <div class="mb-8">
          <p class="text-sm uppercase tracking-widest text-ar-pink font-semibold">เทคโนโลยี #2</p>
          <h2 class="mt-2 text-3xl md:text-4xl font-bold">Aurasma — ผู้นำด้าน AR</h2>
          <p class="mt-3 text-slate-600 dark:text-slate-400 max-w-2xl">
            แอพพลิเคชันสำหรับสร้างสื่อในโลกแห่งความจริงเสมือน (Augmented Reality) — ใช้งานได้ทั้ง iPhone, iPad และ Android
          </p>
        </div>

        <Prose>
          <p>Aurasma เป็นตัวกลางเชื่อมโลกของความจริงและความจริงเสมือนเข้าด้วยกัน แสดงผลในรูปแบบ<strong>สื่อปฏิสัมพันธ์ที่มองเห็น ควบคุม และสัมผัสได้ผ่านหน้าจอ</strong> ทั้งภาพนิ่ง ภาพเคลื่อนไหว เสียง และการเชื่อมโยงไปยังเว็บไซต์</p>
        </Prose>

        <div class="grid md:grid-cols-3 gap-5 mt-8">
          <div class="rounded-3xl p-6 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/40">
            <div class="text-4xl font-black ar-gradient-text">2011</div>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">กำเนิด Aurasma ในต่างประเทศ เผยแพร่ที่ aurasma.com</p>
          </div>
          <div class="rounded-3xl p-6 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/40">
            <div class="text-4xl font-black ar-gradient-text">2555</div>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">ดร.ไพฑูรย์ ศรีฟ้า ม.เกษตรศาสตร์ นำมาใช้สอนนิสิตปริญญาตรี — ผลสำรวจ "สนใจมากที่สุด"</p>
          </div>
          <div class="rounded-3xl p-6 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/40">
            <div class="text-4xl font-black ar-gradient-text">ฟรี</div>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">ดาวน์โหลดได้ที่ App Store และ Play Store ทั้ง iOS และ Android</p>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <ScrollReveal>
      <section>
        <h3 class="text-xl md:text-2xl font-bold mb-5 flex items-center gap-3">
          <span class="w-8 h-1 rounded-full ar-gradient"></span>
          คุณสมบัติของ Aurasma
        </h3>
        <Prose>
          <p>ผู้ใช้สามารถเข้าถึงข้อมูลที่ถูกเข้ารหัสด้วย Aurasma (มองด้วยตาเปล่าไม่เห็น) ให้ปรากฏภาพผ่านหน้าจอ Smart Device เช่น โทรศัพท์มือถือ แท็บเล็ต ที่มีกล้องหลัง — <strong>ไม่ต้องใช้ Marker ไม่ต้องเขียนโปรแกรมควบคุมใดๆ</strong> ใช้งานง่าย ประยุกต์สร้างสื่อได้หลากหลาย เช่น หนังสือพิมพ์ วารสาร ตำรา กล่องบรรจุภัณฑ์ สินค้า เสื้อผ้า และป้ายโฆษณา</p>
          <p>ผลผลิตมีได้ทั้งภาพนิ่ง ภาพเคลื่อนไหว <strong>ภาพ 3 มิติ</strong> และเสียง — หากสร้างเป็นสื่อแบบออนไลน์ยังสามารถกำหนดจุดเชื่อมโยงไปยังเว็บไซต์ได้อีกด้วย</p>
        </Prose>
      </section>
    </ScrollReveal>

    <ScrollReveal>
      <ARViewer
        src="models/horse.glb"
        alt="Horse 3D demo"
        caption="โมเดล 3 มิติอีกตัวอย่างหนึ่ง · ทดสอบการแสดงผลบนอุปกรณ์ของคุณ"
        orbit="45deg 80deg 2.5m"
      />
    </ScrollReveal>

    <ScrollReveal>
      <section class="text-center">
        <a href={`${base}/chapter-3`} class="inline-flex items-center gap-2 px-8 py-4 ar-gradient text-white rounded-full font-semibold shadow-xl shadow-pink-500/20 hover:scale-105 transition">
          ต่อบทที่ 3 · วิธีดำเนินการศึกษา →
        </a>
      </section>
    </ScrollReveal>
  </div>
</BaseLayout>
