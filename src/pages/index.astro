---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ChapterCard from '../components/ChapterCard.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="AR E-Book · เทคโนโลยีความจริงเสริม">
  <Hero />

  <section id="toc" class="max-w-6xl mx-auto px-6 py-20 md:py-28">
    <div class="text-center mb-12">
      <p class="text-sm uppercase tracking-widest text-ar-pink font-semibold">สารบัญ</p>
      <h2 class="mt-3 text-4xl md:text-5xl font-bold">3 บท สู่โลก AR</h2>
      <p class="mt-4 text-slate-600 dark:text-slate-400 max-w-xl mx-auto">
        เริ่มจากที่มาของปัญหา ทำความเข้าใจเทคโนโลยี และรู้จักวิธีดำเนินการศึกษา
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      <ChapterCard
        href={`${base}/chapter-1`}
        number="01"
        title="บทนำ"
        subtitle="ความเป็นมา วัตถุประสงค์ และขอบเขตของการศึกษา AR ในโรงพยาบาล"
        accent="from-ar-purple to-ar-pink"
      />
      <ChapterCard
        href={`${base}/chapter-2`}
        number="02"
        title="เอกสารที่เกี่ยวข้อง"
        subtitle="เทคโนโลยี AR, Aurasma, QR code Line และการประยุกต์ใช้งาน"
        accent="from-ar-pink to-ar-orange"
      />
      <ChapterCard
        href={`${base}/chapter-3`}
        number="03"
        title="วิธีดำเนินการศึกษา"
        subtitle="กลุ่มเป้าหมาย เครื่องมือ ขั้นตอน และการวิเคราะห์ผล"
        accent="from-ar-purple to-ar-orange"
      />
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-20">
    <div class="relative rounded-3xl overflow-hidden p-8 md:p-14 ar-gradient text-white">
      <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 50%, white 1px, transparent 1px); background-size: 24px 24px;"></div>
      <div class="relative max-w-2xl">
        <h3 class="text-3xl md:text-4xl font-bold leading-tight">ลองเล่น AR จริงบนมือถือของคุณ</h3>
        <p class="mt-3 text-white/90">ในบทที่ 2 มี 3D model ให้ส่องกล้องดูในพื้นที่จริงได้ — รองรับ iOS และ Android</p>
        <a href={`${base}/chapter-2`} class="inline-flex mt-6 items-center gap-2 px-6 py-3 bg-white text-slate-900 rounded-full font-semibold hover:scale-105 transition">
          ไปบทที่ 2 →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
