---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ARCube from '../components/ARCube.astro';
import Phone3D from '../components/Phone3D.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const chapters = [
  { n: 'I', href: `${base}/chapter-1`, title: 'บทนำ', en: 'Introduction', page: '3–5',
    blurb: 'ความเป็นมาของปัญหาการสื่อสารทางการพยาบาล และที่มาของการนำ AR เข้ามาใช้' },
  { n: 'II', href: `${base}/chapter-2`, title: 'วรรณกรรมและงานวิจัยที่เกี่ยวข้อง', en: 'Literature Review', page: '6–11',
    blurb: 'ทฤษฎีการสื่อสาร เทคโนโลยีอุปกรณ์เคลื่อนที่ QR Code และแอพพลิเคชัน Aurasma' },
  { n: 'III', href: `${base}/chapter-3`, title: 'วิธีดำเนินการวิจัย', en: 'Methodology', page: '12–13',
    blurb: 'ขั้นตอนการศึกษากึ่งทดลอง เครื่องมือที่ใช้ การทดสอบจริง 44 ราย และการพิทักษ์สิทธิ์' },
];
---
<BaseLayout title="ผลการให้ข้อมูลผู้รับบริการ รพ.นภาลัย ด้วยสื่อมือถือ AR">
  <Hero />

  <!-- Masthead / Publication info -->
  <section id="masthead" class="relative max-w-5xl mx-auto px-6 md:px-10 py-24 md:py-32 scroll-mt-20">
    <div class="ornament justify-center flex mb-10" style="color: #B8954A;">§</div>
    <div class="text-center">
      <div class="eyebrow justify-center" style="color: #B8954A;">Masthead · สำนักพิมพ์</div>
      <h2 class="mt-6 font-display italic text-3xl md:text-5xl leading-tight">
        A journal of <em>augmented reality</em><br/>
        in bedside care
      </h2>
      <div class="gold-line w-24 mx-auto my-10"></div>
      <dl class="grid sm:grid-cols-4 gap-8 max-w-3xl mx-auto">
        <div>
          <dt class="eyebrow justify-center" style="color: #B8954A;">Volume</dt>
          <dd class="mt-2 font-display italic text-xl">I</dd>
        </div>
        <div>
          <dt class="eyebrow justify-center" style="color: #B8954A;">Year</dt>
          <dd class="mt-2 font-display italic text-xl tnum">2560</dd>
        </div>
        <div>
          <dt class="eyebrow justify-center" style="color: #B8954A;">Field</dt>
          <dd class="mt-2 font-display italic text-xl">Nursing</dd>
        </div>
        <div>
          <dt class="eyebrow justify-center" style="color: #B8954A;">Method</dt>
          <dd class="mt-2 font-display italic text-xl">Quasi-experimental</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Abstract -->
  <section class="relative paper-bg-alt">
    <div class="max-w-5xl mx-auto px-6 md:px-10 py-24 md:py-32">
      <div class="grid lg:grid-cols-[220px_1fr] gap-14 lg:gap-20">
        <div>
          <div class="eyebrow mb-5" style="color: #B8954A;">บทคัดย่อ</div>
          <h2 class="font-display italic text-3xl md:text-5xl leading-[1.15]">The <em class="text-gold">Abstract</em></h2>
          <div class="gold-line w-16 mt-6"></div>
        </div>
        <div class="prose-ct max-w-prose font-serif">
          <p class="drop-cap text-lg leading-[1.9]">
            การศึกษานี้เป็นการศึกษา<strong>กึ่งทดลอง</strong>ในผู้รับบริการโรงพยาบาลนภาลัย ตำบลกระดังงา อำเภอบางคนที จังหวัดสมุทรสงคราม จำนวน 20–44 ราย
            โดยทดลองใช้สื่อการให้ข้อมูลผ่านแอพพลิเคชันในมือถือ ได้แก่ <em>Aurasma</em> ซึ่งเป็นเทคโนโลยี Augmented Reality และ <em>QR code LINE</em>
            เพื่อพัฒนารูปแบบการให้ข้อมูลผู้รับบริการจากเดิมที่ใช้เอกสารกระดาษ
          </p>
          <p>
            ดำเนินการระหว่างเดือน<strong>เมษายน ถึง สิงหาคม พ.ศ. 2560</strong> ครอบคลุมกลุ่มโรค<em>แผลเรื้อรัง</em> ผู้ป่วยที่มี<em>อุปกรณ์ต่อพ่วง</em>
            และผู้ป่วยมะเร็งระยะแพร่กระจาย ประเมินผลผ่านแบบประเมินออนไลน์โดยการสแกน QR code
          </p>
          <div class="mt-10 pt-8 border-t hairline flex flex-wrap gap-x-6 gap-y-2 text-xs uppercase tracking-[0.2em] font-sans font-semibold text-sepia">
            <span class="text-ink dark:text-cream">Keywords</span>
            <span>Augmented Reality</span>
            <span>·</span>
            <span>Aurasma</span>
            <span>·</span>
            <span>QR code</span>
            <span>·</span>
            <span>Nursing communication</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Two Technologies: full-bleed spread -->
  <section class="relative ink-bg overflow-hidden">
    <div class="absolute inset-0 opacity-[0.05]" aria-hidden="true"
      style="background-image: radial-gradient(rgba(245,239,228,0.5) 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="relative max-w-6xl mx-auto px-6 md:px-10 py-28 md:py-36">
      <div class="text-center max-w-2xl mx-auto mb-20">
        <div class="eyebrow justify-center" style="color: #B8954A;">Two Technologies</div>
        <h2 class="mt-6 font-display italic text-4xl md:text-6xl leading-[1.1]">
          Two mediums<br/>
          <em class="text-gold">one mission</em>
        </h2>
        <p class="mt-6 font-serif text-lg text-cream/75 leading-[1.85]">
          สองสื่อสำคัญที่เลือกใช้ในการศึกษา เพื่อให้ผู้รับบริการเข้าถึงข้อมูลสุขภาพได้ทั้งบน iOS และ Android
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-16 md:gap-24">
        <div class="relative">
          <div class="flex justify-center py-8">
            <div class="scene-3d"><ARCube size={180} label="AR" /></div>
          </div>
          <div class="gold-line w-16 mx-auto my-8"></div>
          <div class="text-center">
            <div class="eyebrow justify-center" style="color: #B8954A;">Augmented Reality</div>
            <h3 class="mt-4 font-display italic text-3xl md:text-4xl text-cream">Aurasma</h3>
            <p class="mt-5 font-serif text-base md:text-lg text-cream/75 leading-[1.85] max-w-sm mx-auto">
              ผสานโลกจริงกับสื่อดิจิทัล ส่องกล้องมือถือแล้วเห็นภาพ 3 มิติ วิดีโอ หรือคำอธิบายลอยขึ้นในหน้ากระดาษ
              โดยไม่ต้องใช้ Marker
            </p>
          </div>
        </div>

        <div class="relative">
          <div class="flex justify-center py-8">
            <Phone3D variant="qr" />
          </div>
          <div class="gold-line w-16 mx-auto my-8"></div>
          <div class="text-center">
            <div class="eyebrow justify-center" style="color: #B8954A;">Quick Response</div>
            <h3 class="mt-4 font-display italic text-3xl md:text-4xl text-cream">QR · LINE</h3>
            <p class="mt-5 font-serif text-base md:text-lg text-cream/75 leading-[1.85] max-w-sm mx-auto">
              สแกนผ่าน LINE ที่ทุกเครื่องมีอยู่แล้ว เชื่อมไปยังคลิปวีดีโอ คู่มือ หรือแบบประเมินออนไลน์ทันที
              ไม่ต้องพิมพ์ URL
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Table of Contents -->
  <section class="max-w-5xl mx-auto px-6 md:px-10 py-28 md:py-36">
    <div class="grid lg:grid-cols-[220px_1fr] gap-14 lg:gap-20">
      <div>
        <div class="eyebrow mb-5" style="color: #B8954A;">สารบัญ · Contents</div>
        <h2 class="font-display italic text-4xl md:text-5xl leading-[1.1]">The <em class="text-gold">three</em> chapters</h2>
        <div class="gold-line w-16 mt-6"></div>
      </div>
      <ol class="divide-y hairline">
        {chapters.map((c) => (
          <li>
            <a href={c.href} class="group block py-10 md:py-12">
              <div class="grid grid-cols-[60px_1fr_auto] gap-6 md:gap-8 items-baseline">
                <span class="display-num italic text-4xl md:text-5xl text-gold leading-none">{c.n}</span>
                <div>
                  <div class="eyebrow" style="color: #B8954A;">{c.en}</div>
                  <h3 class="mt-3 font-display italic text-2xl md:text-4xl leading-[1.2] text-ink dark:text-cream group-hover:text-gold transition-colors">{c.title}</h3>
                  <p class="mt-3 font-serif text-base md:text-lg text-sepia leading-[1.7] max-w-xl">{c.blurb}</p>
                </div>
                <div class="text-right hidden sm:block">
                  <div class="eyebrow justify-end" style="color: #B8954A;">Page</div>
                  <div class="mt-2 font-display italic text-xl tnum text-sepia">{c.page}</div>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Closing pullquote -->
  <section class="paper-bg-alt">
    <div class="max-w-4xl mx-auto px-6 md:px-10 py-28 md:py-36 text-center">
      <div class="ornament justify-center flex mb-10" style="color: #B8954A;">§</div>
      <blockquote class="font-display italic text-3xl md:text-5xl leading-[1.3] text-ink dark:text-cream">
        <span class="text-gold">"</span>เปลี่ยนการให้คำแนะนำทางด้านสุขภาพ<br/>
        จาก<em class="text-gold">เอกสาร</em> เป็น<em class="text-gold">สื่อมีชีวิต</em><span class="text-gold">"</span>
      </blockquote>
      <div class="mt-8 text-xs uppercase tracking-[0.35em] text-sepia">— หนึ่งในห้าประโยชน์ที่คาดว่าจะได้รับ</div>
      <div class="gold-line w-32 mx-auto my-12"></div>
      <a href={`${base}/chapter-1`} class="inline-flex items-center gap-3 px-8 py-3.5 bg-ink text-cream rounded-none font-sans font-semibold tracking-wider text-sm uppercase hover:bg-burgundy transition">
        เริ่มอ่านบทที่ I
        <span>→</span>
      </a>
    </div>
  </section>
</BaseLayout>
