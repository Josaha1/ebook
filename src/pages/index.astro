---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ARCube from '../components/ARCube.astro';
import Phone3D from '../components/Phone3D.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const chapters = [
  { n: '01', href: `${base}/chapter-1`, title: 'บทนำ', en: 'Introduction',
    blurb: 'ความเป็นมาของปัญหาการสื่อสารทางการพยาบาล และที่มาของการนำ AR เข้ามาใช้ในการให้ข้อมูลผู้รับบริการ' },
  { n: '02', href: `${base}/chapter-2`, title: 'วรรณกรรมและงานวิจัย', en: 'Literature Review',
    blurb: 'ทฤษฎีการสื่อสาร เทคโนโลยีอุปกรณ์เคลื่อนที่ QR Code และแอพพลิเคชัน Aurasma พร้อมตัวอย่างการประยุกต์ใช้งาน' },
  { n: '03', href: `${base}/chapter-3`, title: 'วิธีดำเนินการวิจัย', en: 'Methodology',
    blurb: 'ขั้นตอนการศึกษากึ่งทดลอง เครื่องมือที่ใช้ การทดสอบจริง 44 ราย และการพิทักษ์สิทธิ์' },
];
---
<BaseLayout title="AR E-Book · ผลการให้ข้อมูลผู้รับบริการ รพ.นภาลัย ด้วยสื่อมือถือ">
  <Hero />

  <!-- Abstract -->
  <section id="abstract" class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 md:py-28 scroll-mt-20">
    <div class="grid md:grid-cols-[200px_1fr] gap-8 md:gap-12 lg:gap-16">
      <div>
        <span class="kicker">บทคัดย่อ</span>
        <h2 class="mt-5 font-semibold tracking-tight" style="font-size: clamp(1.75rem, 4vw, 2.5rem);">
          Abstract
        </h2>
      </div>
      <div class="prose-mod max-w-prose">
        <p>
          การศึกษานี้เป็นการศึกษา<strong>กึ่งทดลอง</strong>ในผู้รับบริการโรงพยาบาลนภาลัย ตำบลกระดังงา อำเภอบางคนที จังหวัดสมุทรสงคราม จำนวน 20–44 ราย
          โดยทดลองใช้สื่อการให้ข้อมูลผ่านแอพพลิเคชันในมือถือ ได้แก่ <em>Aurasma</em> ซึ่งเป็นเทคโนโลยี Augmented Reality และ <em>QR code LINE</em>
          เพื่อพัฒนารูปแบบการให้ข้อมูลผู้รับบริการจากเดิมที่ใช้เอกสารกระดาษ
        </p>
        <p>
          ดำเนินการระหว่างเดือน<strong>เมษายน ถึง สิงหาคม พ.ศ. 2560</strong> ครอบคลุมกลุ่มโรคแผลเรื้อรัง ผู้ป่วยที่มีอุปกรณ์ต่อพ่วง
          และผู้ป่วยมะเร็งระยะแพร่กระจาย ประเมินผลผ่านแบบประเมินออนไลน์โดยการสแกน QR code
        </p>
        <div class="mt-8 pt-6 border-t hairline">
          <div class="text-[11px] font-mono uppercase tracking-wider text-zinc-500 mb-3">คำสำคัญ</div>
          <div class="flex flex-wrap gap-2">
            <span class="chip">Augmented Reality</span>
            <span class="chip">Aurasma</span>
            <span class="chip">QR code</span>
            <span class="chip">การพยาบาล</span>
            <span class="chip">โรงพยาบาลนภาลัย</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="border-y hairline bg-gradient-to-br from-zinc-50 to-white dark:from-zinc-900/50 dark:to-[#0A0A0B]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 md:py-24">
      <div class="max-w-2xl">
        <span class="kicker">เทคโนโลยี</span>
        <h2 class="mt-5 font-semibold tracking-tight" style="font-size: clamp(1.75rem, 4vw, 2.5rem);">
          สองสื่อสำคัญ<br/>สู่การให้ข้อมูลยุคใหม่
        </h2>
        <p class="mt-5 text-base md:text-lg text-zinc-600 dark:text-zinc-400 leading-relaxed">
          เลือกใช้เทคโนโลยีสื่อมือถือ 2 รูปแบบ เพื่อให้ผู้รับบริการเข้าถึงข้อมูลสุขภาพได้ทั้งบน iOS และ Android
        </p>
      </div>

      <div class="mt-10 md:mt-14 grid md:grid-cols-2 gap-5 md:gap-6">
        <div class="card card-hover p-6 md:p-8 relative overflow-hidden">
          <div class="absolute -top-20 -right-20 w-48 h-48 brand-gradient opacity-[0.08] rounded-full blur-3xl"></div>
          <div class="relative flex flex-col items-center gap-6">
            <div class="scene-3d py-4"><ARCube size={130} label="AR" /></div>
            <div class="w-full">
              <div class="kicker">Augmented Reality</div>
              <h3 class="mt-3 text-2xl md:text-3xl font-semibold">Aurasma</h3>
              <p class="mt-3 text-sm md:text-base text-zinc-600 dark:text-zinc-400 leading-relaxed">
                ผสานโลกจริงกับสื่อดิจิทัล ส่องกล้องมือถือแล้วเห็นภาพ 3 มิติ วิดีโอ หรือคำอธิบายลอยขึ้นมา ไม่ต้องใช้ Marker
              </p>
            </div>
          </div>
        </div>

        <div class="card card-hover p-6 md:p-8 relative overflow-hidden">
          <div class="absolute -top-20 -right-20 w-48 h-48 bg-indigo-500 opacity-[0.08] rounded-full blur-3xl"></div>
          <div class="relative flex flex-col items-center gap-6">
            <Phone3D variant="qr" />
            <div class="w-full">
              <div class="kicker">Quick Response</div>
              <h3 class="mt-3 text-2xl md:text-3xl font-semibold">QR · LINE</h3>
              <p class="mt-3 text-sm md:text-base text-zinc-600 dark:text-zinc-400 leading-relaxed">
                สแกนผ่าน LINE ที่ทุกเครื่องมีอยู่แล้ว เชื่อมไปยังคลิปวีดีโอ คู่มือ หรือแบบประเมินออนไลน์ทันที
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Table of Contents -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 md:py-28">
    <div class="flex items-end justify-between mb-10 md:mb-14 flex-wrap gap-4">
      <div>
        <span class="kicker">สารบัญ</span>
        <h2 class="mt-5 font-semibold tracking-tight" style="font-size: clamp(1.75rem, 4vw, 2.5rem);">
          เนื้อหาทั้งหมด
        </h2>
      </div>
      <div class="text-sm font-mono text-zinc-500 tnum">3 / 3 บท</div>
    </div>

    <ol class="space-y-3 md:space-y-4">
      {chapters.map((c) => (
        <li>
          <a href={c.href} class="card card-hover group block p-5 md:p-8 relative overflow-hidden">
            <div class="absolute -top-20 -right-20 w-48 h-48 brand-gradient opacity-0 group-hover:opacity-[0.06] rounded-full blur-3xl transition-opacity"></div>
            <div class="relative grid sm:grid-cols-[auto_1fr_auto] gap-4 sm:gap-6 md:gap-8 items-start">
              <div class="flex sm:block items-center gap-4">
                <div class="font-semibold text-3xl sm:text-5xl md:text-6xl brand-gradient-text tnum leading-none">{c.n}</div>
                <div class="sm:mt-2 text-[11px] font-mono uppercase tracking-wider text-zinc-500">{c.en}</div>
              </div>
              <div class="min-w-0">
                <h3 class="font-semibold leading-tight" style="font-size: clamp(1.25rem, 2.5vw, 1.625rem);">{c.title}</h3>
                <p class="mt-2 text-sm md:text-base text-zinc-600 dark:text-zinc-400 leading-relaxed">{c.blurb}</p>
              </div>
              <div class="hidden sm:flex text-indigo-600 dark:text-indigo-400 text-2xl items-center h-full group-hover:translate-x-1 transition">→</div>
            </div>
          </a>
        </li>
      ))}
    </ol>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 md:pb-24">
    <div class="relative overflow-hidden rounded-3xl p-8 md:p-12 lg:p-16 bg-zinc-900 dark:bg-zinc-100 text-white dark:text-zinc-900">
      <div class="absolute inset-0 brand-gradient opacity-20"></div>
      <div class="relative grid md:grid-cols-[1.6fr_1fr] gap-8 items-center">
        <div>
          <span class="kicker" style="background: rgba(255,255,255,0.1); color: white;">Interactive Demo</span>
          <h3 class="mt-5 font-semibold leading-tight tracking-tight" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
            ลองเล่นเทคโนโลยี AR จริง<br/>ในบทที่ 2
          </h3>
          <p class="mt-4 text-base md:text-lg opacity-80 max-w-lg leading-relaxed">
            มีแบบจำลอง 3 มิติให้ส่องดูผ่านมือถือ · รองรับทั้ง iOS และ Android
          </p>
          <a href={`${base}/chapter-2`} class="btn btn-primary mt-6 sm:mt-8" style="background: white; color: #0A0A0B;">
            ไปบทที่ 2
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="hidden md:flex justify-center md:justify-end">
          <ARCube size={130} label="AR" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
