---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ARCube from '../components/ARCube.astro';
import Phone3D from '../components/Phone3D.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const chapters = [
  { n: '01', href: `${base}/chapter-1`, title: 'บทนำ', en: 'Introduction',
    blurb: 'ความเป็นมาของปัญหาการสื่อสารทางการพยาบาล และที่มาของการนำ AR เข้ามาใช้ในการให้ข้อมูลผู้รับบริการ',
    items: ['ความเป็นมาและความสำคัญ', 'วัตถุประสงค์ · ประโยชน์', 'ขอบเขต · นิยามศัพท์', 'กลุ่มเป้าหมาย'] },
  { n: '02', href: `${base}/chapter-2`, title: 'วรรณกรรมและงานวิจัยที่เกี่ยวข้อง', en: 'Literature Review',
    blurb: 'ทฤษฎีการสื่อสาร เทคโนโลยีอุปกรณ์เคลื่อนที่ QR Code และแอพพลิเคชัน Aurasma พร้อมตัวอย่างการประยุกต์ใช้งาน',
    items: ['กระบวนการสื่อสาร', 'QR Code · Barcode', 'Aurasma · AR', 'ตัวอย่างการประยุกต์'] },
  { n: '03', href: `${base}/chapter-3`, title: 'วิธีดำเนินการวิจัย', en: 'Methodology',
    blurb: 'ขั้นตอนการศึกษากึ่งทดลอง เครื่องมือที่ใช้ การทดสอบกับผู้รับบริการจริง 44 ราย และการพิทักษ์สิทธิ์',
    items: ['ขั้นเตรียมการ', 'ขั้นดำเนินการ', 'เครื่องมือวิจัย', 'การพิทักษ์สิทธิ์'] },
];
---
<BaseLayout title="ผลการให้ข้อมูลผู้รับบริการ รพ.นภาลัย ด้วยสื่อมือถือ AR">
  <Hero />

  <!-- Abstract -->
  <section id="abstract" class="relative max-w-5xl mx-auto px-6 py-24 md:py-28 scroll-mt-20">
    <div class="grid lg:grid-cols-[200px_1fr] gap-10 lg:gap-16">
      <div>
        <div class="title-eyebrow">บทคัดย่อ · Abstract</div>
        <h2 class="mt-5 font-serif text-3xl md:text-4xl font-bold leading-tight">ภาพรวม<br/>การศึกษา</h2>
        <div class="mt-6 h-px bg-slate-300 dark:bg-slate-700 w-16"></div>
      </div>
      <div class="prose-academic max-w-prose">
        <p class="dropcap">
          การศึกษานี้เป็นการศึกษา<strong>กึ่งทดลอง</strong>ในผู้รับบริการโรงพยาบาลนภาลัย ตำบลกระดังงา อำเภอบางคนที จังหวัดสมุทรสงคราม จำนวน 20–44 ราย
          โดยทดลองใช้สื่อการให้ข้อมูลผ่านแอพพลิเคชันในมือถือ ได้แก่ <em>Aurasma</em> ซึ่งเป็นเทคโนโลยี Augmented Reality และ <em>QR code LINE</em>
          เพื่อพัฒนารูปแบบการให้ข้อมูลผู้รับบริการจากเดิมที่ใช้เอกสารกระดาษ ให้เข้าถึงสะดวก ลดต้นทุน และทันยุคสมัย
        </p>
        <p>
          ดำเนินการระหว่างเดือน<strong>เมษายน ถึง สิงหาคม พ.ศ. 2560</strong> ครอบคลุมกลุ่มโรค<em>แผลเรื้อรัง</em> ผู้ป่วยที่มี<em>อุปกรณ์ต่อพ่วง</em>
          และผู้ป่วยมะเร็งระยะแพร่กระจาย ประเมินผลผ่านแบบประเมินออนไลน์โดยการสแกน QR code
        </p>
        <div class="mt-8 pt-6 border-t border-slate-300 dark:border-slate-700 flex flex-wrap gap-x-6 gap-y-2 text-sm font-sans text-slate-600 dark:text-slate-400">
          <span><strong class="text-slate-900 dark:text-slate-100">คำสำคัญ:</strong></span>
          <span>Augmented Reality</span><span>·</span>
          <span>Aurasma</span><span>·</span>
          <span>QR code</span><span>·</span>
          <span>การพยาบาล</span><span>·</span>
          <span>โรงพยาบาลนภาลัย</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="relative border-y border-slate-200 dark:border-slate-800">
    <div class="absolute inset-0 ar-grid-bg opacity-50" aria-hidden="true"></div>
    <div class="relative max-w-5xl mx-auto px-6 py-24">
      <div class="max-w-2xl">
        <div class="title-eyebrow">เทคโนโลยีที่ใช้</div>
        <h2 class="mt-5 font-serif text-3xl md:text-[2.5rem] font-bold leading-[1.2]">สองสื่อสำคัญ<br/>สู่การให้ข้อมูลยุคใหม่</h2>
        <p class="mt-5 text-slate-600 dark:text-slate-400 leading-relaxed font-serif text-lg">
          การศึกษาเลือกใช้เทคโนโลยีสื่อมือถือ 2 รูปแบบ เพื่อให้ผู้รับบริการเข้าถึงข้อมูลสุขภาพได้ทั้งบน iOS และ Android
        </p>
      </div>

      <div class="mt-14 grid md:grid-cols-2 gap-8 md:gap-10">
        <div class="paper rounded-lg p-8 md:p-10 flex flex-col gap-8 relative overflow-hidden">
          <div class="absolute -top-16 -right-16 w-40 h-40 ar-gradient opacity-[0.08] rounded-full blur-2xl"></div>
          <div class="flex justify-center py-4">
            <div class="scene-3d"><ARCube size={140} label="AR" /></div>
          </div>
          <div>
            <div class="title-eyebrow">เทคโนโลยี AR</div>
            <h3 class="mt-3 font-serif text-2xl font-bold">แอพพลิเคชัน Aurasma</h3>
            <p class="mt-4 text-base text-slate-700 dark:text-slate-300 leading-[1.85]">
              ผสานโลกจริงกับสื่อดิจิทัล — ส่องกล้องมือถือแล้วเห็นภาพ 3 มิติ วิดีโอ หรือคำอธิบายลอยขึ้นมาในหน้ากระดาษได้โดยไม่ต้องใช้ Marker
            </p>
          </div>
        </div>

        <div class="paper rounded-lg p-8 md:p-10 flex flex-col gap-8 relative overflow-hidden">
          <div class="absolute -top-16 -right-16 w-40 h-40 bg-cyan-500 opacity-[0.08] rounded-full blur-2xl"></div>
          <div class="flex justify-center">
            <Phone3D variant="qr" />
          </div>
          <div>
            <div class="title-eyebrow text-cyan-700 dark:text-cyan-300">เทคโนโลยี QR</div>
            <h3 class="mt-3 font-serif text-2xl font-bold">QR code ใน LINE</h3>
            <p class="mt-4 text-base text-slate-700 dark:text-slate-300 leading-[1.85]">
              สแกนผ่าน LINE ที่ทุกเครื่องมีอยู่แล้ว เชื่อมไปยังคลิปวีดีโอ คู่มือ หรือแบบประเมินออนไลน์ได้ทันทีโดยไม่ต้องพิมพ์ URL
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Table of Contents -->
  <section id="toc" class="max-w-5xl mx-auto px-6 py-24 md:py-28">
    <div class="flex items-end justify-between mb-14 pb-8 border-b border-slate-300 dark:border-slate-700">
      <div>
        <div class="title-eyebrow">สารบัญ · Contents</div>
        <h2 class="mt-5 font-serif text-3xl md:text-[2.5rem] font-bold leading-[1.15]">เนื้อหาทั้งหมด</h2>
      </div>
      <div class="text-sm font-sans text-slate-500 font-semibold tnum">3 บท</div>
    </div>

    <ol class="divide-y divide-slate-300 dark:divide-slate-700">
      {chapters.map((c, i) => (
        <li>
          <a href={c.href} class="group py-8 md:py-10 flex flex-col md:flex-row gap-6 md:gap-10 items-start md:items-center transition hover:bg-slate-50/60 dark:hover:bg-slate-900/30 -mx-4 px-4 rounded">
            <div class="shrink-0 w-full md:w-[140px]">
              <div class="display-num text-6xl md:text-7xl ar-gradient-text leading-none">{c.n}</div>
              <div class="mt-2 text-[10px] uppercase tracking-[0.25em] text-slate-500 font-sans">{c.en}</div>
            </div>

            <div class="flex-1 min-w-0 max-w-3xl">
              <h3 class="font-serif text-xl md:text-2xl font-bold leading-tight">{c.title}</h3>
              <p class="mt-3 text-base text-slate-600 dark:text-slate-400 leading-[1.85] font-serif max-w-2xl">{c.blurb}</p>
              <ul class="mt-4 flex flex-wrap gap-x-5 gap-y-1.5 text-sm font-sans text-slate-500 dark:text-slate-400">
                {c.items.map((it) => (<li class="flex gap-1.5 items-center"><span class="w-1 h-1 rounded-full bg-purple-700 dark:bg-purple-400"></span>{it}</li>))}
              </ul>
            </div>

            <div class="hidden md:block text-purple-700 dark:text-purple-300 text-3xl transition-transform group-hover:translate-x-1 shrink-0">→</div>
          </a>
        </li>
      ))}
    </ol>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-6 pb-24">
    <div class="relative overflow-hidden rounded-lg ar-gradient p-10 md:p-14 text-white">
      <div class="absolute inset-0 ar-dot-bg opacity-20" style="color: white;"></div>
      <div class="relative grid md:grid-cols-[1.6fr_1fr] gap-10 items-center">
        <div>
          <div class="title-eyebrow" style="color: rgba(255,255,255,0.8);">Interactive Demo</div>
          <h3 class="mt-4 font-serif text-3xl md:text-4xl font-bold leading-tight">ลองเล่นเทคโนโลยี AR จริง<br/>ในบทที่ 2</h3>
          <p class="mt-4 text-white/90 font-serif text-lg">มีแบบจำลอง 3 มิติให้ส่องดูผ่านมือถือ — รองรับทั้ง iOS และ Android</p>
          <a href={`${base}/chapter-2`} class="inline-flex mt-7 items-center gap-2 px-7 py-3.5 bg-white text-slate-900 rounded-lg font-serif font-semibold hover:scale-[1.02] transition">
            ไปบทที่ 2 →
          </a>
        </div>
        <div class="flex justify-center md:justify-end">
          <ARCube size={140} label="AR" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
