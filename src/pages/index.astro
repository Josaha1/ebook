---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const chapters = [
  { n: '01', href: `${base}/chapter-1`, title: 'บทนำ',
    items: ['ความเป็นมาและความสำคัญของปัญหา', 'วัตถุประสงค์', 'ประโยชน์ที่คาดว่าจะได้รับ', 'ขอบเขตการศึกษา', 'นิยามศัพท์', 'กลุ่มเป้าหมาย'] },
  { n: '02', href: `${base}/chapter-2`, title: 'วรรณกรรมและงานวิจัยที่เกี่ยวข้อง',
    items: ['กระบวนการสื่อสาร', 'การสื่อสารทางการพยาบาล', 'เทคโนโลยีอุปกรณ์เคลื่อนที่', 'QR Code และการประยุกต์ใช้', 'แอพพลิเคชัน Aurasma', 'ตัวอย่างการประยุกต์ใช้'] },
  { n: '03', href: `${base}/chapter-3`, title: 'วิธีดำเนินการศึกษา',
    items: ['ขั้นเตรียมการ', 'ขั้นดำเนินการ', 'เครื่องมือที่ใช้', 'การพิทักษ์สิทธิ์'] },
];
---
<BaseLayout title="ผลการให้ข้อมูลผู้รับบริการ รพ.นภาลัย ด้วยสื่อมือถือ">
  <Hero />

  <section class="max-w-5xl mx-auto px-6 py-20 md:py-24">
    <div class="paper rounded-2xl p-6 md:p-10 shadow-sm">
      <div class="text-xs uppercase tracking-widest text-slate-500 dark:text-slate-400 font-semibold">บทคัดย่อ · Abstract</div>
      <h2 class="mt-3 text-2xl md:text-3xl font-bold">ภาพรวมการศึกษา</h2>
      <div class="mt-5 space-y-4 text-slate-700 dark:text-slate-300 leading-[1.9]">
        <p>
          การศึกษานี้เป็นการศึกษา<strong>กึ่งทดลอง</strong>ในผู้รับบริการโรงพยาบาลนภาลัย ตำบลกระดังงา อำเภอบางคนที จังหวัดสมุทรสงคราม จำนวน 20–44 ราย
          โดยทดลองใช้สื่อการให้ข้อมูลผ่านแอพพลิเคชันในมือถือ ได้แก่ <strong>Aurasma</strong> และ <strong>QR code LINE</strong>
          เพื่อพัฒนารูปแบบการให้ข้อมูลผู้รับบริการจากเดิมที่ใช้เอกสารกระดาษ ให้เข้าถึงสะดวก ลดต้นทุน และทันยุคสมัย
        </p>
        <p>
          ดำเนินการระหว่างเดือน<strong>เมษายน ถึง สิงหาคม พ.ศ. 2560</strong> ครอบคลุมกลุ่มโรคแผลเรื้อรัง ผู้ป่วยที่มีอุปกรณ์ต่อพ่วง และผู้ป่วยมะเร็งระยะแพร่กระจาย
          ประเมินผลผ่านแบบประเมินออนไลน์โดยการสแกน QR code
        </p>
      </div>
    </div>
  </section>

  <section id="toc" class="max-w-5xl mx-auto px-6 pb-20">
    <div class="flex items-baseline justify-between mb-10">
      <div>
        <div class="text-xs uppercase tracking-widest text-slate-500 dark:text-slate-400 font-semibold">สารบัญ · Table of Contents</div>
        <h2 class="mt-2 text-3xl md:text-4xl font-bold">เนื้อหาทั้งหมด</h2>
      </div>
      <div class="text-sm text-slate-500 dark:text-slate-400">3 บท</div>
    </div>

    <ol class="space-y-4">
      {chapters.map((c) => (
        <li>
          <a href={c.href} class="group paper rounded-2xl p-6 md:p-8 flex flex-col md:flex-row md:items-center gap-4 md:gap-8 hover:shadow-lg transition">
            <div class="flex items-center gap-5 md:min-w-[220px]">
              <div class="text-4xl md:text-5xl font-black ar-gradient-text leading-none font-display">{c.n}</div>
              <div>
                <div class="text-xs uppercase tracking-widest text-slate-500 dark:text-slate-400">บทที่ {parseInt(c.n)}</div>
                <h3 class="text-xl md:text-2xl font-bold">{c.title}</h3>
              </div>
            </div>
            <ul class="flex-1 grid sm:grid-cols-2 gap-x-6 gap-y-1 text-sm text-slate-600 dark:text-slate-400">
              {c.items.map((it) => (<li class="flex gap-2"><span class="text-purple-600 dark:text-purple-400">·</span><span>{it}</span></li>))}
            </ul>
            <div class="text-purple-700 dark:text-purple-300 text-2xl transition-transform group-hover:translate-x-1">→</div>
          </a>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>
